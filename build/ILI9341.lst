 158:./Application/Src/ILI9341.c ****     lcd_data(0x23);
 159:./Application/Src/ILI9341.c **** 
 160:./Application/Src/ILI9341.c ****     // power control 2
 161:./Application/Src/ILI9341.c ****     lcd_cmd(0xC1);
