 166:./Application/Src/ILI9341.c ****     lcd_data(0x3E);
 167:./Application/Src/ILI9341.c ****     lcd_data(0x28);
 168:./Application/Src/ILI9341.c **** 
 169:./Application/Src/ILI9341.c ****     // VCOM control 2
 170:./Application/Src/ILI9341.c ****     lcd_cmd(0xC7);
 171:./Application/Src/ILI9341.c ****     lcd_data(0x86);
 172:./Application/Src/ILI9341.c **** 
 173:./Application/Src/ILI9341.c ****     // memory access control - 0x08 for portrait, BGR
