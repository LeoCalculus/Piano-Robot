 250:./Application/Src/ILI9341.c ****     LCD_soft_reset(cfg);
 251:./Application/Src/ILI9341.c **** 
 252:./Application/Src/ILI9341.c ****     // display off during init
 253:./Application/Src/ILI9341.c ****     LCD_display_off(cfg);
 254:./Application/Src/ILI9341.c **** 
 255:./Application/Src/ILI9341.c ****     // power settings (defaults)
 256:./Application/Src/ILI9341.c ****     LCD_set_power(cfg, 0x23, 0x10, 0x3E, 0x28, 0x86);
 257:./Application/Src/ILI9341.c **** 
 258:./Application/Src/ILI9341.c ****     // display settings: orientation (0xA8 for landscape, 0x68 for portrait), pixel format (0x55 fo
 259:./Application/Src/ILI9341.c ****     LCD_set_display(cfg, 0xA8, 0x55, 0x00, 0x18);
 260:./Application/Src/ILI9341.c **** 
 261:./Application/Src/ILI9341.c ****     // display function control
 262:./Application/Src/ILI9341.c ****     LCD_set_function(cfg, 0x08, 0x82, 0x27);
 263:./Application/Src/ILI9341.c **** 
 264:./Application/Src/ILI9341.c ****     // exit sleep
 265:./Application/Src/ILI9341.c ****     LCD_sleep_out(cfg);
 266:./Application/Src/ILI9341.c **** 
 267:./Application/Src/ILI9341.c ****     // turn on display
 268:./Application/Src/ILI9341.c ****     LCD_display_on(cfg);
 269:./Application/Src/ILI9341.c ****     HAL_Delay(50);
 270:./Application/Src/ILI9341.c **** 
 271:./Application/Src/ILI9341.c ****     // clear screen
 272:./Application/Src/ILI9341.c ****     LCD_fill_screen(cfg, COLOR_WHITE);
 273:./Application/Src/ILI9341.c **** }
