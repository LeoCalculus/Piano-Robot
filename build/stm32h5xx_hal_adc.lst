6798:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h **** __STATIC_INLINE void LL_ADC_DisableInternalRegulator(ADC_TypeDef *ADCx)
6799:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h **** {
