 191:./Application/Src/ILI9225.c **** void LCD_init(void) {
 192:./Application/Src/ILI9225.c ****     LCD_unselect();
 193:./Application/Src/ILI9225.c ****     LCD_reset();
 194:./Application/Src/ILI9225.c **** 
 195:./Application/Src/ILI9225.c ****     // ---------- Power-on sequence (from ILI9225 datasheet) ----------
 196:./Application/Src/ILI9225.c **** 
 197:./Application/Src/ILI9225.c ****     // Power control 2: set step-up circuit
 198:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_POWER_CTRL2, 0x0018);
 199:./Application/Src/ILI9225.c ****     // Power control 3: set operating frequency
 200:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_POWER_CTRL3, 0x6121);
 201:./Application/Src/ILI9225.c ****     // Power control 4: VREG1OUT voltage
 202:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_POWER_CTRL4, 0x006F);
 203:./Application/Src/ILI9225.c ****     // Power control 5: VCOM amplitude
 204:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_POWER_CTRL5, 0x495F);
 205:./Application/Src/ILI9225.c ****     // Power control 1: start power supply
 206:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_POWER_CTRL1, 0x0800);
 207:./Application/Src/ILI9225.c ****     HAL_Delay(10);
 208:./Application/Src/ILI9225.c **** 
 209:./Application/Src/ILI9225.c ****     // Power control 2: step-up circuit 2
 210:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_POWER_CTRL2, 0x103B);
 211:./Application/Src/ILI9225.c ****     HAL_Delay(50);
 212:./Application/Src/ILI9225.c **** 
 213:./Application/Src/ILI9225.c ****     // ---------- Display control ----------
 214:./Application/Src/ILI9225.c **** 
 215:./Application/Src/ILI9225.c ****     // Driver output control: SS=0, GS=1, NL=28 (220 lines) - landscape
 216:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_DRIVER_OUTPUT_CTRL, 0x011C);
 217:./Application/Src/ILI9225.c ****     // LCD AC driving control: line inversion
 218:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_LCD_AC_DRIVING_CTRL, 0x0100);
 219:./Application/Src/ILI9225.c ****     // Entry mode: BGR, AM=1 (vertical first), ID1=0 ID0=1 - landscape
 220:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_ENTRY_MODE, 0x1028);
 221:./Application/Src/ILI9225.c **** 
 222:./Application/Src/ILI9225.c ****     // Blank period control
 223:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_BLANK_PERIOD_CTRL1, 0x0808);
 224:./Application/Src/ILI9225.c ****     // Frame cycle control
 225:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_FRAME_CYCLE_CTRL, 0x1100);
 226:./Application/Src/ILI9225.c ****     // Interface control
 227:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_INTERFACE_CTRL, 0x0000);
 228:./Application/Src/ILI9225.c ****     // Oscillator control: enable oscillator
 229:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_OSC_CTRL, 0x0D01);
 230:./Application/Src/ILI9225.c ****     // VCI recycling
 231:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_VCI_RECYCLING, 0x0020);
 232:./Application/Src/ILI9225.c **** 
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\cc6qX2tw.s 			page 12


 233:./Application/Src/ILI9225.c ****     // ---------- RAM address ----------
 234:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_RAM_ADDR_SET1, 0x0000);
 235:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_RAM_ADDR_SET2, 0x0000);
 236:./Application/Src/ILI9225.c **** 
 237:./Application/Src/ILI9225.c ****     // ---------- Gate scan control ----------
 238:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GATE_SCAN_CTRL, 0x0000);
 239:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_VERTICAL_SCROLL_CTRL1, 0x00DB);
 240:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_VERTICAL_SCROLL_CTRL2, 0x0000);
 241:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_VERTICAL_SCROLL_CTRL3, 0x0000);
 242:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_PARTIAL_DRIVING_POS1, 0x00DB);
 243:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_PARTIAL_DRIVING_POS2, 0x0000);
 244:./Application/Src/ILI9225.c **** 
 245:./Application/Src/ILI9225.c ****     // ---------- Window address (full screen, landscape) ----------
 246:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_HORIZONTAL_WINDOW_ADDR1, 0x00AF); // 175 (physical horizontal)
 247:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_HORIZONTAL_WINDOW_ADDR2, 0x0000);
 248:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_VERTICAL_WINDOW_ADDR1, 0x00DB); // 219 (physical vertical)
 249:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_VERTICAL_WINDOW_ADDR2, 0x0000);
 250:./Application/Src/ILI9225.c **** 
 251:./Application/Src/ILI9225.c ****     // ---------- Gamma control ----------
 252:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL1, 0x0000);
 253:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL2, 0x0808);
 254:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL3, 0x080A);
 255:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL4, 0x000A);
 256:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL5, 0x0A08);
 257:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL6, 0x0808);
 258:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL7, 0x0000);
 259:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL8, 0x0A00);
 260:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL9, 0x0710);
 261:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_GAMMA_CTRL10, 0x0710);
 262:./Application/Src/ILI9225.c **** 
 263:./Application/Src/ILI9225.c ****     // ---------- Display ON ----------
 264:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_DISP_CTRL1, 0x0012);
 265:./Application/Src/ILI9225.c ****     HAL_Delay(50);
 266:./Application/Src/ILI9225.c ****     LCD_write_reg(ILI9225_DISP_CTRL1, 0x1017);
 267:./Application/Src/ILI9225.c **** 
 268:./Application/Src/ILI9225.c ****     // clear screen
 269:./Application/Src/ILI9225.c ****     LCD_fill_screen(COLOR_WHITE);
 270:./Application/Src/ILI9225.c **** }
