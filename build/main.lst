 203:Core/Src/main.c **** 
 204:Core/Src/main.c ****       // Reset BEFORE processing so interrupt can receive next packet
 205:Core/Src/main.c ****       rx_binary_complete = 0;
 206:Core/Src/main.c ****       rx_binary_index = 0;
 207:Core/Src/main.c **** 
 208:Core/Src/main.c ****       // Now safely process the copy
 209:Core/Src/main.c ****       FT_ProcessPacket(packet_copy, packet_len);
 210:Core/Src/main.c ****     }
 211:Core/Src/main.c **** 
