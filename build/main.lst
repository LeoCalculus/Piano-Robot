 197:Core/Src/main.c ****     // Process file transfer binary packets
 198:Core/Src/main.c ****     if (rx_binary_complete) {
 199:Core/Src/main.c ****       // Copy packet data BEFORE resetting - prevents race condition with interrupt
 200:Core/Src/main.c ****       uint8_t packet_copy[80];
 201:Core/Src/main.c ****       uint16_t packet_len = rx_binary_index;
 202:Core/Src/main.c ****       memcpy(packet_copy, rx_binary_buffer, packet_len);
