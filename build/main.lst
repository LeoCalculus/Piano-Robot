 257:Core/Src/main.c ****                     /* Look for start sentinel (514.114f) in received data */
 258:Core/Src/main.c ****                     const float start_sentinel = RAM_SENTINEL_START;
 259:Core/Src/main.c ****                     int found = 0;
 260:Core/Src/main.c ****                     for (int i = 0; i <= (int)valid_rx - 4; i++)
 261:Core/Src/main.c ****                     {
 262:Core/Src/main.c ****                         if (memcmp(&rx_buffer[i], &start_sentinel, 4) == 0)
 263:Core/Src/main.c ****                         {
 264:Core/Src/main.c ****                             ram_rx_started = 1;
 265:Core/Src/main.c ****                             ram_rx_offset = 0;
 266:Core/Src/main.c ****                             /* Copy any data after sentinel into song_ram */
 267:Core/Src/main.c ****                             int remaining = valid_rx - (i + 4);
 268:Core/Src/main.c ****                             if (remaining > 0)
 269:Core/Src/main.c ****                             {
 270:Core/Src/main.c ****                                 uint32_t copy_len = ((uint32_t)remaining < RAM_SONG_MAX_BYTES) ? (u
 271:Core/Src/main.c ****                                 memcpy((uint8_t *)song_ram, &rx_buffer[i + 4], copy_len);
 272:Core/Src/main.c ****                                 ram_rx_offset = copy_len;
 273:Core/Src/main.c ****                             }
 274:Core/Src/main.c ****                             found = 1;
 275:Core/Src/main.c ****                             break;
 276:Core/Src/main.c ****                         }
 277:Core/Src/main.c ****                     }
 278:Core/Src/main.c ****                     if (!found)
 279:Core/Src/main.c ****                     {
 280:Core/Src/main.c ****                         /* Not song data — treat as text command (allows :a back) */
 281:Core/Src/main.c ****                         executeCommand(rx_buffer);
 282:Core/Src/main.c ****                     }
 283:Core/Src/main.c ****                 }
 284:Core/Src/main.c ****                 else
 285:Core/Src/main.c ****                 {
 286:Core/Src/main.c ****                     /* Accumulate song data into song_ram */
 287:Core/Src/main.c ****                     uint32_t space = RAM_SONG_MAX_BYTES - ram_rx_offset;
 288:Core/Src/main.c ****                     uint32_t copy_len = (valid_rx < space) ? valid_rx : space;
 289:Core/Src/main.c ****                     memcpy(&((uint8_t *)song_ram)[ram_rx_offset], rx_buffer, copy_len);
 290:Core/Src/main.c ****                     ram_rx_offset += copy_len;
 291:Core/Src/main.c **** 
 292:Core/Src/main.c ****                     /* Check last 4 bytes for end sentinel (114.514f) */
 293:Core/Src/main.c ****                     const float end_sentinel = RAM_SENTINEL_END;
 294:Core/Src/main.c ****                     if (ram_rx_offset >= 4)
 295:Core/Src/main.c ****                     {
 296:Core/Src/main.c ****                         float last_float;
