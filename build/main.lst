 203:Core/Src/main.c ****     // Process file transfer binary packets
 204:Core/Src/main.c ****     if (rx_binary_complete) {
 205:Core/Src/main.c ****       // Copy packet data BEFORE resetting - prevents race condition with interrupt
 206:Core/Src/main.c ****       uint8_t packet_copy[80];
 207:Core/Src/main.c ****       uint16_t packet_len = rx_binary_index;
 208:Core/Src/main.c ****       memcpy(packet_copy, rx_binary_buffer, packet_len);
 209:Core/Src/main.c **** 
 210:Core/Src/main.c ****       // Reset BEFORE processing so interrupt can receive next packet
 211:Core/Src/main.c ****       rx_binary_complete = 0;
 212:Core/Src/main.c ****       rx_binary_index = 0;
 213:Core/Src/main.c **** 
 214:Core/Src/main.c ****       // Now safely process the copy
 215:Core/Src/main.c ****       FT_ProcessPacket(packet_copy, packet_len);
 216:Core/Src/main.c ****     }
 217:Core/Src/main.c **** 
 218:Core/Src/main.c ****     // Check for file transfer timeout
 219:Core/Src/main.c ****     FT_TimeoutCheck();
 220:Core/Src/main.c **** 
 221:Core/Src/main.c ****     // only process when complete message received
 222:Core/Src/main.c ****   #ifdef USINGHC05
 223:Core/Src/main.c ****     if(rx_complete){
 224:Core/Src/main.c ****       // OLED_SetCursor(0, 5);
 225:Core/Src/main.c ****       // OLED_WriteString((char*)rx_data);  // cast to char*
 226:Core/Src/main.c ****       executeCommand(rx_data);
 227:Core/Src/main.c ****       rx_complete = 0;  // clear flag
 228:Core/Src/main.c ****       // echo back with \r\n for terminal
 229:Core/Src/main.c ****       HC05_SendInfo((uint8_t*)"Got it!\r\n");
 230:Core/Src/main.c ****     }
 231:Core/Src/main.c ****     // HC05_SendInfo((uint8_t*)"Still Alive!\r\n");  // Disabled during file transfer
 232:Core/Src/main.c ****   #endif
 233:Core/Src/main.c **** 
 234:Core/Src/main.c **** 
 235:Core/Src/main.c **** 
 236:Core/Src/main.c ****     // dynamic pwm from 40%->100%, 40% -> 200, 100% -> 500
 237:Core/Src/main.c ****     if (pwmNum < 500) {
 238:Core/Src/main.c ****       pwmNum++;
 239:Core/Src/main.c ****     } else {
 240:Core/Src/main.c ****       pwmNum = 200;
 241:Core/Src/main.c ****     }
 242:Core/Src/main.c ****     __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, pwmNum);
 243:Core/Src/main.c ****   }
 244:Core/Src/main.c ****   /* USER CODE END 3 */
 245:Core/Src/main.c **** }
