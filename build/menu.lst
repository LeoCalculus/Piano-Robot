 468:./Application/Src/menu.c ****                     break;
 469:./Application/Src/menu.c ****                 case 1: /* Transmit Song to SD card */
 470:./Application/Src/menu.c ****                     menu_state = MENU_STATE_TRANSMIT;
 471:./Application/Src/menu.c ****                     page_dirty = 1;
 472:./Application/Src/menu.c ****                     uart_binary_mode = 1;
 473:./Application/Src/menu.c ****                     FT_Init(); /* Reset transfer state */
 474:./Application/Src/menu.c ****                     break;
 475:./Application/Src/menu.c ****                 case 2: /* Transmit Song to RAM */
 476:./Application/Src/menu.c ****                     menu_state = MENU_STATE_TRANSMIT_RAM;
 477:./Application/Src/menu.c ****                     page_dirty = 1;
 478:./Application/Src/menu.c ****                     uart_binary_mode = 1;
