 184:./Application/Src/menu.c **** /* ------------------------------------------------------------------ */
 185:./Application/Src/menu.c **** /*  Dispatch incoming UART data to the right handler                  */
 186:./Application/Src/menu.c **** /* ------------------------------------------------------------------ */
 187:./Application/Src/menu.c **** 
 188:./Application/Src/menu.c **** void menu_process_message(uint8_t *data, uint16_t len)
 189:./Application/Src/menu.c **** {
 190:./Application/Src/menu.c ****     if (len == 0) return;
 191:./Application/Src/menu.c **** 
 192:./Application/Src/menu.c ****     MenuState_t state = menu_get_state();
 193:./Application/Src/menu.c **** 
 194:./Application/Src/menu.c ****     if (state == MENU_STATE_TRANSMIT &&
 195:./Application/Src/menu.c ****         data[0] >= 0xF0 && data[0] <= 0xF3)
 196:./Application/Src/menu.c ****     {
 197:./Application/Src/menu.c ****         /* File transfer packet → SD card */
 198:./Application/Src/menu.c ****         FT_ProcessPacket(data, len);
 199:./Application/Src/menu.c ****     }
 200:./Application/Src/menu.c ****     else if (state == MENU_STATE_TRANSMIT_RAM && data[0] >= 0xE0 && data[0] <= 0xE2)
 201:./Application/Src/menu.c ****     {
 202:./Application/Src/menu.c ****         /* Raw binary → RAM accumulation */
 203:./Application/Src/menu.c ****         // RAM_AccumulateData(data, len);
 204:./Application/Src/menu.c ****         RAM_ProcessPacket(data, len);
 205:./Application/Src/menu.c ****     }
 206:./Application/Src/menu.c ****     else
 207:./Application/Src/menu.c ****     {
 208:./Application/Src/menu.c ****         /* Text command */
 209:./Application/Src/menu.c ****         data[len] = '\0';
 210:./Application/Src/menu.c ****         if (len > 0 && data[len - 1] == '\n') data[len - 1] = '\0';
 211:./Application/Src/menu.c ****         execute_command(data);
 212:./Application/Src/menu.c ****     }
 213:./Application/Src/menu.c **** }
 214:./Application/Src/menu.c **** 
 215:./Application/Src/menu.c **** /* Try to dispatch accumulated binary bytes (called from main loop).
 216:./Application/Src/menu.c ****    Returns 1 if data was consumed, 0 if still waiting for more bytes. */
 217:./Application/Src/menu.c **** int menu_try_dispatch_binary(uint8_t *data, uint16_t len)
 218:./Application/Src/menu.c **** {
 219:./Application/Src/menu.c ****     if (len == 0) return 0;
 220:./Application/Src/menu.c **** 
 221:./Application/Src/menu.c ****     // check for MENU in transmit state and waiting for file data packets (0xF0-0xF3)
 222:./Application/Src/menu.c ****     if (menu_get_state() == MENU_STATE_TRANSMIT &&
 223:./Application/Src/menu.c ****         data[0] >= 0xF0 && data[0] <= 0xF3)
 224:./Application/Src/menu.c ****     {
 225:./Application/Src/menu.c ****         uint16_t need = 0;
 226:./Application/Src/menu.c ****         switch (data[0]) {
 227:./Application/Src/menu.c ****           case FT_CMD_FILE_START: need = FT_FILE_START_SIZE; break;
 228:./Application/Src/menu.c ****           case FT_CMD_FILE_DATA:  need = (len >= 4) ? (uint16_t)(5 + data[3]) : 0xFFFF; break;
 229:./Application/Src/menu.c ****           case FT_CMD_FILE_END:   need = FT_FILE_END_SIZE; break;
 230:./Application/Src/menu.c ****           case FT_CMD_FILE_ABORT: need = FT_FILE_ABORT_SIZE; break;
 231:./Application/Src/menu.c ****         }
 232:./Application/Src/menu.c ****         if (need == 0 || len < need)
 233:./Application/Src/menu.c ****             return 0; /* not enough bytes yet */
 234:./Application/Src/menu.c **** 
 235:./Application/Src/menu.c ****         menu_process_message(data, len);
 236:./Application/Src/menu.c ****         return 1;
 237:./Application/Src/menu.c ****     }
 238:./Application/Src/menu.c **** 
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccQmSmxd.s 			page 17


 239:./Application/Src/menu.c ****     // check for MENU in transmit RAM state and waiting for RAM packets (0xE0-0xE2)
 240:./Application/Src/menu.c ****     if (menu_get_state() == MENU_STATE_TRANSMIT_RAM &&
 241:./Application/Src/menu.c ****         data[0] >= 0xE0 && data[0] <= 0xE2)
 242:./Application/Src/menu.c ****     {
 243:./Application/Src/menu.c ****         uint16_t need = 0;
 244:./Application/Src/menu.c ****         switch (data[0]) {
 245:./Application/Src/menu.c ****           case FT_CMD_RAM_START: need = 2; break;   // [0xE0] [sentinel]
 246:./Application/Src/menu.c ****           case FT_CMD_RAM_DATA:  need = 60; break;   // [0xE1] [row_lo] [row_hi] [56 data] [checksu
 247:./Application/Src/menu.c ****           case FT_CMD_RAM_END:   need = 2; break;   // [0xE2] [sentinel]
 248:./Application/Src/menu.c ****         }
 249:./Application/Src/menu.c ****         if (need == 0 || len < need)
 250:./Application/Src/menu.c ****             return 0; /* not enough bytes yet */
 251:./Application/Src/menu.c **** 
 252:./Application/Src/menu.c ****         menu_process_message(data, len);
 253:./Application/Src/menu.c ****         return 1;
 254:./Application/Src/menu.c ****     }
 255:./Application/Src/menu.c **** 
 256:./Application/Src/menu.c ****     /* Everything else (text commands) — dispatch immediately */
 257:./Application/Src/menu.c ****     menu_process_message(data, len);
 258:./Application/Src/menu.c ****     return 1;
 259:./Application/Src/menu.c **** }
