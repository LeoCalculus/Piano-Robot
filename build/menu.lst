 331:./Application/Src/menu.c ****         switch (data[0]) {
 332:./Application/Src/menu.c ****           case FT_CMD_FILE_START: need = FT_FILE_START_SIZE; break;
 333:./Application/Src/menu.c ****           case FT_CMD_FILE_DATA:  need = (len >= 4) ? (uint16_t)(5 + data[3]) : 0xFFFF; break;
 334:./Application/Src/menu.c ****           case FT_CMD_FILE_END:   need = FT_FILE_END_SIZE; break;
 335:./Application/Src/menu.c ****           case FT_CMD_FILE_ABORT: need = FT_FILE_ABORT_SIZE; break;
 336:./Application/Src/menu.c ****         }
 337:./Application/Src/menu.c ****         if (need == 0 || len < need)
 338:./Application/Src/menu.c ****             return 0;
 339:./Application/Src/menu.c **** 
