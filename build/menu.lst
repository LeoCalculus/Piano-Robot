 239:./Application/Src/menu.c ****     // check for MENU in transmit RAM state and waiting for RAM packets (0xE0-0xE2)
 240:./Application/Src/menu.c ****     if (menu_get_state() == MENU_STATE_TRANSMIT_RAM &&
 241:./Application/Src/menu.c ****         data[0] >= 0xE0 && data[0] <= 0xE2)
 242:./Application/Src/menu.c ****     {
 243:./Application/Src/menu.c ****         uint16_t need = 0;
 244:./Application/Src/menu.c ****         switch (data[0]) {
 245:./Application/Src/menu.c ****           case FT_CMD_RAM_START: need = 2; break;   // [0xE0] [sentinel]
 246:./Application/Src/menu.c ****           case FT_CMD_RAM_DATA:  need = 60; break;   // [0xE1] [row_lo] [row_hi] [56 data] [checksu
 247:./Application/Src/menu.c ****           case FT_CMD_RAM_END:   need = 2; break;   // [0xE2] [sentinel]
 248:./Application/Src/menu.c ****         }
 249:./Application/Src/menu.c ****         if (need == 0 || len < need)
 250:./Application/Src/menu.c ****             return 0; /* not enough bytes yet */
 251:./Application/Src/menu.c **** 
 252:./Application/Src/menu.c ****         menu_process_message(data, len);
 253:./Application/Src/menu.c ****         return 1;
 254:./Application/Src/menu.c ****     }
 255:./Application/Src/menu.c **** 
 256:./Application/Src/menu.c ****     /* Everything else (text commands) — dispatch immediately */
 257:./Application/Src/menu.c ****     menu_process_message(data, len);
 258:./Application/Src/menu.c ****     return 1;
 259:./Application/Src/menu.c **** }
