 147:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c **** /**
 148:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   * @brief Initialize the RS485 Driver enable feature according to the specified
 149:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *         parameters in the UART_InitTypeDef and creates the associated handle.
 150:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   * @param huart            UART handle.
 151:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   * @param Polarity         Select the driver enable polarity.
 152:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *          This parameter can be one of the following values:
 153:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *          @arg @ref UART_DE_POLARITY_HIGH DE signal is active high
 154:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *          @arg @ref UART_DE_POLARITY_LOW  DE signal is active low
 155:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   * @param AssertionTime    Driver Enable assertion time:
 156:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *       5-bit value defining the time between the activation of the DE (Driver Enable)
 157:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *       signal and the beginning of the start bit. It is expressed in sample time
 158:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *       units (1/8 or 1/16 bit time, depending on the oversampling rate)
 159:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   * @param DeassertionTime  Driver Enable deassertion time:
 160:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *       5-bit value defining the time between the end of the last stop bit, in a
 161:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *       transmitted message, and the de-activation of the DE (Driver Enable) signal.
 162:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *       It is expressed in sample time units (1/8 or 1/16 bit time, depending on the
 163:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   *       oversampling rate).
 164:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   * @retval HAL status
 165:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   */
 166:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c **** HAL_StatusTypeDef HAL_RS485Ex_Init(UART_HandleTypeDef *huart, uint32_t Polarity, uint32_t Assertion
 167:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****                                    uint32_t DeassertionTime)
 168:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c **** {
 169:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   uint32_t temp;
 170:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c **** 
 171:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   /* Check the UART handle allocation */
 172:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_uart_ex.c ****   if (huart == NULL)
