2909:./ThirdParty/FatFs/ff.c **** 				ST_DWORD(dir + DIR_WrtTime, tm);
2910:./ThirdParty/FatFs/ff.c **** 				ST_WORD(dir + DIR_LstAccDate, 0);
2911:./ThirdParty/FatFs/ff.c **** 				fp->flag &= ~FA__WRITTEN;
2912:./ThirdParty/FatFs/ff.c **** 				fp->fs->wflag = 1;
2913:./ThirdParty/FatFs/ff.c **** 				res = sync_fs(fp->fs);
2914:./ThirdParty/FatFs/ff.c **** 			}
2915:./ThirdParty/FatFs/ff.c **** 		}
2916:./ThirdParty/FatFs/ff.c **** 	}
2917:./ThirdParty/FatFs/ff.c **** 
2918:./ThirdParty/FatFs/ff.c **** 	LEAVE_FF(fp->fs, res);
2919:./ThirdParty/FatFs/ff.c **** }
