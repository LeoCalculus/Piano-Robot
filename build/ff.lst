1043:./Application/FatFs/ff.c **** 				disk_ioctl(fs->drv, CTRL_TRIM, rt);				/* Erase the block */
1044:./Application/FatFs/ff.c **** 				scl = ecl = nxt;
1045:./Application/FatFs/ff.c **** 			}
1046:./Application/FatFs/ff.c **** #endif
1047:./Application/FatFs/ff.c **** 			clst = nxt;	/* Next cluster */
1048:./Application/FatFs/ff.c **** 		}
1049:./Application/FatFs/ff.c **** 	}
1050:./Application/FatFs/ff.c **** 
1051:./Application/FatFs/ff.c **** 	return res;
1052:./Application/FatFs/ff.c **** }
