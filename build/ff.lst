 657:./ThirdParty/FatFs/ff.c **** /* File lock control functions                                           */
 658:./ThirdParty/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 659:./ThirdParty/FatFs/ff.c **** #if _FS_LOCK
 660:./ThirdParty/FatFs/ff.c **** 
 661:./ThirdParty/FatFs/ff.c **** static
 662:./ThirdParty/FatFs/ff.c **** FRESULT chk_lock (	/* Check if the file can be accessed */
 663:./ThirdParty/FatFs/ff.c **** 	DIR* dp,		/* Directory object pointing the file to be checked */
 664:./ThirdParty/FatFs/ff.c **** 	int acc			/* Desired access type (0:Read, 1:Write, 2:Delete/Rename) */
 665:./ThirdParty/FatFs/ff.c **** )
 666:./ThirdParty/FatFs/ff.c **** {
 667:./ThirdParty/FatFs/ff.c **** 	UINT i, be;
 668:./ThirdParty/FatFs/ff.c **** 
 669:./ThirdParty/FatFs/ff.c **** 	/* Search file semaphore table */
 670:./ThirdParty/FatFs/ff.c **** 	for (i = be = 0; i < _FS_LOCK; i++) {
 671:./ThirdParty/FatFs/ff.c **** 		if (Files[i].fs) {	/* Existing entry */
 672:./ThirdParty/FatFs/ff.c **** 			if (Files[i].fs == dp->fs &&	 	/* Check if the object matched with an open object */
 673:./ThirdParty/FatFs/ff.c **** 				Files[i].clu == dp->sclust &&
 674:./ThirdParty/FatFs/ff.c **** 				Files[i].idx == dp->index) break;
 675:./ThirdParty/FatFs/ff.c **** 		} else {			/* Blank entry */
 676:./ThirdParty/FatFs/ff.c **** 			be = 1;
 677:./ThirdParty/FatFs/ff.c **** 		}
 678:./ThirdParty/FatFs/ff.c **** 	}
 679:./ThirdParty/FatFs/ff.c **** 	if (i == _FS_LOCK)	/* The object is not opened */
 680:./ThirdParty/FatFs/ff.c **** 		return (be || acc == 2) ? FR_OK : FR_TOO_MANY_OPEN_FILES;	/* Is there a blank entry for new objec
 681:./ThirdParty/FatFs/ff.c **** 
 682:./ThirdParty/FatFs/ff.c **** 	/* The object has been opened. Reject any open against writing file and all write mode open */
 683:./ThirdParty/FatFs/ff.c **** 	return (acc || Files[i].ctr == 0x100) ? FR_LOCKED : FR_OK;
 684:./ThirdParty/FatFs/ff.c **** }
 685:./ThirdParty/FatFs/ff.c **** 
 686:./ThirdParty/FatFs/ff.c **** 
 687:./ThirdParty/FatFs/ff.c **** static
 688:./ThirdParty/FatFs/ff.c **** int enq_lock (void)	/* Check if an entry is available for a new object */
 689:./ThirdParty/FatFs/ff.c **** {
 690:./ThirdParty/FatFs/ff.c **** 	UINT i;
 691:./ThirdParty/FatFs/ff.c **** 
 692:./ThirdParty/FatFs/ff.c **** 	for (i = 0; i < _FS_LOCK && Files[i].fs; i++) ;
 693:./ThirdParty/FatFs/ff.c **** 	return (i == _FS_LOCK) ? 0 : 1;
 694:./ThirdParty/FatFs/ff.c **** }
 695:./ThirdParty/FatFs/ff.c **** 
 696:./ThirdParty/FatFs/ff.c **** 
 697:./ThirdParty/FatFs/ff.c **** static
 698:./ThirdParty/FatFs/ff.c **** UINT inc_lock (	/* Increment object open counter and returns its index (0:Internal error) */
 699:./ThirdParty/FatFs/ff.c **** 	DIR* dp,	/* Directory object pointing the file to register or increment */
 700:./ThirdParty/FatFs/ff.c **** 	int acc		/* Desired access (0:Read, 1:Write, 2:Delete/Rename) */
 701:./ThirdParty/FatFs/ff.c **** )
 702:./ThirdParty/FatFs/ff.c **** {
 703:./ThirdParty/FatFs/ff.c **** 	UINT i;
 704:./ThirdParty/FatFs/ff.c **** 
 705:./ThirdParty/FatFs/ff.c **** 
 706:./ThirdParty/FatFs/ff.c **** 	for (i = 0; i < _FS_LOCK; i++) {	/* Find the object */
 707:./ThirdParty/FatFs/ff.c **** 		if (Files[i].fs == dp->fs &&
 708:./ThirdParty/FatFs/ff.c **** 			Files[i].clu == dp->sclust &&
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccLX7nbq.s 			page 17


 709:./ThirdParty/FatFs/ff.c **** 			Files[i].idx == dp->index) break;
 710:./ThirdParty/FatFs/ff.c **** 	}
 711:./ThirdParty/FatFs/ff.c **** 
 712:./ThirdParty/FatFs/ff.c **** 	if (i == _FS_LOCK) {				/* Not opened. Register it as new. */
 713:./ThirdParty/FatFs/ff.c **** 		for (i = 0; i < _FS_LOCK && Files[i].fs; i++) ;
 714:./ThirdParty/FatFs/ff.c **** 		if (i == _FS_LOCK) return 0;	/* No free entry to register (int err) */
 715:./ThirdParty/FatFs/ff.c **** 		Files[i].fs = dp->fs;
 716:./ThirdParty/FatFs/ff.c **** 		Files[i].clu = dp->sclust;
 717:./ThirdParty/FatFs/ff.c **** 		Files[i].idx = dp->index;
 718:./ThirdParty/FatFs/ff.c **** 		Files[i].ctr = 0;
 719:./ThirdParty/FatFs/ff.c **** 	}
 720:./ThirdParty/FatFs/ff.c **** 
 721:./ThirdParty/FatFs/ff.c **** 	if (acc && Files[i].ctr) return 0;	/* Access violation (int err) */
 722:./ThirdParty/FatFs/ff.c **** 
 723:./ThirdParty/FatFs/ff.c **** 	Files[i].ctr = acc ? 0x100 : Files[i].ctr + 1;	/* Set semaphore value */
 724:./ThirdParty/FatFs/ff.c **** 
 725:./ThirdParty/FatFs/ff.c **** 	return i + 1;
 726:./ThirdParty/FatFs/ff.c **** }
 727:./ThirdParty/FatFs/ff.c **** 
 728:./ThirdParty/FatFs/ff.c **** 
 729:./ThirdParty/FatFs/ff.c **** static
 730:./ThirdParty/FatFs/ff.c **** FRESULT dec_lock (	/* Decrement object open counter */
 731:./ThirdParty/FatFs/ff.c **** 	UINT i			/* Semaphore index (1..) */
 732:./ThirdParty/FatFs/ff.c **** )
 733:./ThirdParty/FatFs/ff.c **** {
 734:./ThirdParty/FatFs/ff.c **** 	WORD n;
 735:./ThirdParty/FatFs/ff.c **** 	FRESULT res;
 736:./ThirdParty/FatFs/ff.c **** 
 737:./ThirdParty/FatFs/ff.c **** 
 738:./ThirdParty/FatFs/ff.c **** 	if (--i < _FS_LOCK) {	/* Shift index number origin from 0 */
 739:./ThirdParty/FatFs/ff.c **** 		n = Files[i].ctr;
 740:./ThirdParty/FatFs/ff.c **** 		if (n == 0x100) n = 0;		/* If write mode open, delete the entry */
 741:./ThirdParty/FatFs/ff.c **** 		if (n) n--;					/* Decrement read mode open count */
 742:./ThirdParty/FatFs/ff.c **** 		Files[i].ctr = n;
 743:./ThirdParty/FatFs/ff.c **** 		if (!n) Files[i].fs = 0;	/* Delete the entry if open count gets zero */
 744:./ThirdParty/FatFs/ff.c **** 		res = FR_OK;
 745:./ThirdParty/FatFs/ff.c **** 	} else {
 746:./ThirdParty/FatFs/ff.c **** 		res = FR_INT_ERR;			/* Invalid index nunber */
 747:./ThirdParty/FatFs/ff.c **** 	}
 748:./ThirdParty/FatFs/ff.c **** 	return res;
 749:./ThirdParty/FatFs/ff.c **** }
 750:./ThirdParty/FatFs/ff.c **** 
 751:./ThirdParty/FatFs/ff.c **** 
 752:./ThirdParty/FatFs/ff.c **** static
 753:./ThirdParty/FatFs/ff.c **** void clear_lock (	/* Clear lock entries of the volume */
 754:./ThirdParty/FatFs/ff.c **** 	FATFS *fs
 755:./ThirdParty/FatFs/ff.c **** )
 756:./ThirdParty/FatFs/ff.c **** {
 757:./ThirdParty/FatFs/ff.c **** 	UINT i;
 758:./ThirdParty/FatFs/ff.c **** 
 759:./ThirdParty/FatFs/ff.c **** 	for (i = 0; i < _FS_LOCK; i++) {
 760:./ThirdParty/FatFs/ff.c **** 		if (Files[i].fs == fs) Files[i].fs = 0;
 761:./ThirdParty/FatFs/ff.c **** 	}
 762:./ThirdParty/FatFs/ff.c **** }
