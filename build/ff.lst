1074:./Application/FatFs/ff.c **** 		if (!scl || scl >= fs->n_fatent) scl = 1;
1075:./Application/FatFs/ff.c **** 	}
1076:./Application/FatFs/ff.c **** 	else {					/* Stretch the current chain */
1077:./Application/FatFs/ff.c **** 		cs = get_fat(fs, clst);			/* Check the cluster status */
