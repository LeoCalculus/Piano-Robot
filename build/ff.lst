2124:./Application/FatFs/ff.c **** static
2125:./Application/FatFs/ff.c **** FRESULT follow_path (	/* FR_OK(0): successful, !=0: error code */
2126:./Application/FatFs/ff.c **** 	DIR* dp,			/* Directory object to return last directory and found object */
2127:./Application/FatFs/ff.c **** 	const TCHAR* path	/* Full-path string to find a file or directory */
2128:./Application/FatFs/ff.c **** )
2129:./Application/FatFs/ff.c **** {
2130:./Application/FatFs/ff.c **** 	FRESULT res;
2131:./Application/FatFs/ff.c **** 	BYTE *dir, ns;
2132:./Application/FatFs/ff.c **** 
2133:./Application/FatFs/ff.c **** 
2134:./Application/FatFs/ff.c **** #if _FS_RPATH
2135:./Application/FatFs/ff.c **** 	if (*path == '/' || *path == '\\') {	/* There is a heading separator */
2136:./Application/FatFs/ff.c **** 		path++;	dp->sclust = 0;				/* Strip it and start from the root directory */
2137:./Application/FatFs/ff.c **** 	} else {								/* No heading separator */
2138:./Application/FatFs/ff.c **** 		dp->sclust = dp->fs->cdir;			/* Start from the current directory */
2139:./Application/FatFs/ff.c **** 	}
2140:./Application/FatFs/ff.c **** #else
