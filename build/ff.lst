3749:./ThirdParty/FatFs/Src/ff.c **** 
3750:./ThirdParty/FatFs/Src/ff.c **** 
3751:./ThirdParty/FatFs/Src/ff.c **** 	/* Get volume ID (logical drive number) */
3752:./ThirdParty/FatFs/Src/ff.c **** 	vol = get_ldnumber(&rp);
3753:./ThirdParty/FatFs/Src/ff.c **** 	if (vol < 0) return FR_INVALID_DRIVE;
3754:./ThirdParty/FatFs/Src/ff.c **** 
3755:./ThirdParty/FatFs/Src/ff.c **** 	cfs = FatFs[vol];			/* Pointer to the filesystem object of the volume */
3756:./ThirdParty/FatFs/Src/ff.c **** 	if (cfs) {					/* Unregister current filesystem object */
3757:./ThirdParty/FatFs/Src/ff.c **** 		FatFs[vol] = 0;
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccTDbepL.s 			page 153


3758:./ThirdParty/FatFs/Src/ff.c **** #if FF_FS_LOCK					/* Clear file lock semaphores correspond to this volume */
3759:./ThirdParty/FatFs/Src/ff.c **** 		clear_share(cfs);
3760:./ThirdParty/FatFs/Src/ff.c **** #endif
3761:./ThirdParty/FatFs/Src/ff.c **** #if FF_FS_REENTRANT				/* Discard mutex of the current volume */
3762:./ThirdParty/FatFs/Src/ff.c **** 		ff_mutex_delete(vol);
3763:./ThirdParty/FatFs/Src/ff.c **** #endif
3764:./ThirdParty/FatFs/Src/ff.c **** 		cfs->fs_type = 0;		/* Invalidate the filesystem object to be unregistered */
3765:./ThirdParty/FatFs/Src/ff.c **** 	}
3766:./ThirdParty/FatFs/Src/ff.c **** 
3767:./ThirdParty/FatFs/Src/ff.c **** 	if (fs) {					/* Register new filesystem object */
3768:./ThirdParty/FatFs/Src/ff.c **** 		fs->pdrv = LD2PD(vol);	/* Volume hosting physical drive */
3769:./ThirdParty/FatFs/Src/ff.c **** #if FF_FS_REENTRANT				/* Create a volume mutex */
3770:./ThirdParty/FatFs/Src/ff.c **** 		fs->ldrv = (BYTE)vol;	/* Owner volume ID */
3771:./ThirdParty/FatFs/Src/ff.c **** 		if (!ff_mutex_create(vol)) return FR_INT_ERR;
3772:./ThirdParty/FatFs/Src/ff.c **** #if FF_FS_LOCK
3773:./ThirdParty/FatFs/Src/ff.c **** 		if (SysLock == 0) {		/* Create a system mutex if needed */
3774:./ThirdParty/FatFs/Src/ff.c **** 			if (!ff_mutex_create(FF_VOLUMES)) {
3775:./ThirdParty/FatFs/Src/ff.c **** 				ff_mutex_delete(vol);
3776:./ThirdParty/FatFs/Src/ff.c **** 				return FR_INT_ERR;
3777:./ThirdParty/FatFs/Src/ff.c **** 			}
