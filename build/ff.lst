1008:./Application/FatFs/ff.c **** #if !_FS_READONLY
1009:./Application/FatFs/ff.c **** static
1010:./Application/FatFs/ff.c **** FRESULT remove_chain (
1011:./Application/FatFs/ff.c **** 	FATFS* fs,			/* File system object */
1012:./Application/FatFs/ff.c **** 	DWORD clst			/* Cluster# to remove a chain from */
1013:./Application/FatFs/ff.c **** )
1014:./Application/FatFs/ff.c **** {
1015:./Application/FatFs/ff.c **** 	FRESULT res;
1016:./Application/FatFs/ff.c **** 	DWORD nxt;
1017:./Application/FatFs/ff.c **** #if _USE_TRIM
1018:./Application/FatFs/ff.c **** 	DWORD scl = clst, ecl = clst, rt[2];
1019:./Application/FatFs/ff.c **** #endif
1020:./Application/FatFs/ff.c **** 
1021:./Application/FatFs/ff.c **** 	if (clst < 2 || clst >= fs->n_fatent) {	/* Check range */
1022:./Application/FatFs/ff.c **** 		res = FR_INT_ERR;
1023:./Application/FatFs/ff.c **** 
1024:./Application/FatFs/ff.c **** 	} else {
1025:./Application/FatFs/ff.c **** 		res = FR_OK;
1026:./Application/FatFs/ff.c **** 		while (clst < fs->n_fatent) {			/* Not a last link? */
1027:./Application/FatFs/ff.c **** 			nxt = get_fat(fs, clst);			/* Get cluster status */
1028:./Application/FatFs/ff.c **** 			if (nxt == 0) break;				/* Empty cluster? */
1029:./Application/FatFs/ff.c **** 			if (nxt == 1) { res = FR_INT_ERR; break; }	/* Internal error? */
1030:./Application/FatFs/ff.c **** 			if (nxt == 0xFFFFFFFF) { res = FR_DISK_ERR; break; }	/* Disk error? */
