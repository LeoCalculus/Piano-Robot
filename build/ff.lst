 156:./Application/FatFs/ff.c **** /* Definitions of sector size */
 157:./Application/FatFs/ff.c **** #if (_MAX_SS < _MIN_SS) || (_MAX_SS != 512 && _MAX_SS != 1024 && _MAX_SS != 2048 && _MAX_SS != 4096
 158:./Application/FatFs/ff.c **** #error Wrong sector size configuration
 159:./Application/FatFs/ff.c **** #endif
 160:./Application/FatFs/ff.c **** #if _MAX_SS == _MIN_SS
 161:./Application/FatFs/ff.c **** #define	SS(fs)	((UINT)_MAX_SS)	/* Fixed sector size */
 162:./Application/FatFs/ff.c **** #else
 163:./Application/FatFs/ff.c **** #define	SS(fs)	((fs)->ssize)	/* Variable sector size */
 164:./Application/FatFs/ff.c **** #endif
 165:./Application/FatFs/ff.c **** 
 166:./Application/FatFs/ff.c **** 
 167:./Application/FatFs/ff.c **** /* Timestamp feature */
 168:./Application/FatFs/ff.c **** #if _FS_NORTC == 1
 169:./Application/FatFs/ff.c **** #if _NORTC_YEAR < 1980 || _NORTC_YEAR > 2107 || _NORTC_MON < 1 || _NORTC_MON > 12 || _NORTC_MDAY < 
 170:./Application/FatFs/ff.c **** #error Invalid _FS_NORTC settings
 171:./Application/FatFs/ff.c **** #endif
 172:./Application/FatFs/ff.c **** #define GET_FATTIME()	((DWORD)(_NORTC_YEAR - 1980) << 25 | (DWORD)_NORTC_MON << 21 | (DWORD)_NORTC_
 173:./Application/FatFs/ff.c **** #else
 174:./Application/FatFs/ff.c **** #define GET_FATTIME()	get_fattime()
 175:./Application/FatFs/ff.c **** #endif
 176:./Application/FatFs/ff.c **** 
 177:./Application/FatFs/ff.c **** 
 178:./Application/FatFs/ff.c **** /* File access control feature */
 179:./Application/FatFs/ff.c **** #if _FS_LOCK
 180:./Application/FatFs/ff.c **** #if _FS_READONLY
 181:./Application/FatFs/ff.c **** #error _FS_LOCK must be 0 at read-only configuration
 182:./Application/FatFs/ff.c **** #endif
 183:./Application/FatFs/ff.c **** typedef struct {
 184:./Application/FatFs/ff.c **** 	FATFS *fs;		/* Object ID 1, volume (NULL:blank entry) */
 185:./Application/FatFs/ff.c **** 	DWORD clu;		/* Object ID 2, directory (0:root) */
 186:./Application/FatFs/ff.c **** 	WORD idx;		/* Object ID 3, directory index */
 187:./Application/FatFs/ff.c **** 	WORD ctr;		/* Object open counter, 0:none, 0x01..0xFF:read mode open count, 0x100:write mode */
 188:./Application/FatFs/ff.c **** } FILESEM;
 189:./Application/FatFs/ff.c **** #endif
