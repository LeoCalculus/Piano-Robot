 657:./Application/FatFs/ff.c **** /* File lock control functions                                           */
 658:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 659:./Application/FatFs/ff.c **** #if _FS_LOCK
 660:./Application/FatFs/ff.c **** 
 661:./Application/FatFs/ff.c **** static
 662:./Application/FatFs/ff.c **** FRESULT chk_lock (	/* Check if the file can be accessed */
 663:./Application/FatFs/ff.c **** 	DIR* dp,		/* Directory object pointing the file to be checked */
 664:./Application/FatFs/ff.c **** 	int acc			/* Desired access type (0:Read, 1:Write, 2:Delete/Rename) */
 665:./Application/FatFs/ff.c **** )
 666:./Application/FatFs/ff.c **** {
 667:./Application/FatFs/ff.c **** 	UINT i, be;
 668:./Application/FatFs/ff.c **** 
 669:./Application/FatFs/ff.c **** 	/* Search file semaphore table */
 670:./Application/FatFs/ff.c **** 	for (i = be = 0; i < _FS_LOCK; i++) {
 671:./Application/FatFs/ff.c **** 		if (Files[i].fs) {	/* Existing entry */
 672:./Application/FatFs/ff.c **** 			if (Files[i].fs == dp->fs &&	 	/* Check if the object matched with an open object */
 673:./Application/FatFs/ff.c **** 				Files[i].clu == dp->sclust &&
 674:./Application/FatFs/ff.c **** 				Files[i].idx == dp->index) break;
 675:./Application/FatFs/ff.c **** 		} else {			/* Blank entry */
 676:./Application/FatFs/ff.c **** 			be = 1;
 677:./Application/FatFs/ff.c **** 		}
 678:./Application/FatFs/ff.c **** 	}
 679:./Application/FatFs/ff.c **** 	if (i == _FS_LOCK)	/* The object is not opened */
 680:./Application/FatFs/ff.c **** 		return (be || acc == 2) ? FR_OK : FR_TOO_MANY_OPEN_FILES;	/* Is there a blank entry for new objec
 681:./Application/FatFs/ff.c **** 
 682:./Application/FatFs/ff.c **** 	/* The object has been opened. Reject any open against writing file and all write mode open */
 683:./Application/FatFs/ff.c **** 	return (acc || Files[i].ctr == 0x100) ? FR_LOCKED : FR_OK;
 684:./Application/FatFs/ff.c **** }
 685:./Application/FatFs/ff.c **** 
 686:./Application/FatFs/ff.c **** 
 687:./Application/FatFs/ff.c **** static
 688:./Application/FatFs/ff.c **** int enq_lock (void)	/* Check if an entry is available for a new object */
 689:./Application/FatFs/ff.c **** {
 690:./Application/FatFs/ff.c **** 	UINT i;
 691:./Application/FatFs/ff.c **** 
 692:./Application/FatFs/ff.c **** 	for (i = 0; i < _FS_LOCK && Files[i].fs; i++) ;
 693:./Application/FatFs/ff.c **** 	return (i == _FS_LOCK) ? 0 : 1;
 694:./Application/FatFs/ff.c **** }
 695:./Application/FatFs/ff.c **** 
 696:./Application/FatFs/ff.c **** 
 697:./Application/FatFs/ff.c **** static
 698:./Application/FatFs/ff.c **** UINT inc_lock (	/* Increment object open counter and returns its index (0:Internal error) */
 699:./Application/FatFs/ff.c **** 	DIR* dp,	/* Directory object pointing the file to register or increment */
 700:./Application/FatFs/ff.c **** 	int acc		/* Desired access (0:Read, 1:Write, 2:Delete/Rename) */
 701:./Application/FatFs/ff.c **** )
 702:./Application/FatFs/ff.c **** {
 703:./Application/FatFs/ff.c **** 	UINT i;
 704:./Application/FatFs/ff.c **** 
 705:./Application/FatFs/ff.c **** 
 706:./Application/FatFs/ff.c **** 	for (i = 0; i < _FS_LOCK; i++) {	/* Find the object */
 707:./Application/FatFs/ff.c **** 		if (Files[i].fs == dp->fs &&
 708:./Application/FatFs/ff.c **** 			Files[i].clu == dp->sclust &&
 709:./Application/FatFs/ff.c **** 			Files[i].idx == dp->index) break;
 710:./Application/FatFs/ff.c **** 	}
 711:./Application/FatFs/ff.c **** 
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccJzsbqh.s 			page 17


 712:./Application/FatFs/ff.c **** 	if (i == _FS_LOCK) {				/* Not opened. Register it as new. */
 713:./Application/FatFs/ff.c **** 		for (i = 0; i < _FS_LOCK && Files[i].fs; i++) ;
 714:./Application/FatFs/ff.c **** 		if (i == _FS_LOCK) return 0;	/* No free entry to register (int err) */
 715:./Application/FatFs/ff.c **** 		Files[i].fs = dp->fs;
 716:./Application/FatFs/ff.c **** 		Files[i].clu = dp->sclust;
 717:./Application/FatFs/ff.c **** 		Files[i].idx = dp->index;
 718:./Application/FatFs/ff.c **** 		Files[i].ctr = 0;
 719:./Application/FatFs/ff.c **** 	}
 720:./Application/FatFs/ff.c **** 
 721:./Application/FatFs/ff.c **** 	if (acc && Files[i].ctr) return 0;	/* Access violation (int err) */
 722:./Application/FatFs/ff.c **** 
 723:./Application/FatFs/ff.c **** 	Files[i].ctr = acc ? 0x100 : Files[i].ctr + 1;	/* Set semaphore value */
 724:./Application/FatFs/ff.c **** 
 725:./Application/FatFs/ff.c **** 	return i + 1;
 726:./Application/FatFs/ff.c **** }
 727:./Application/FatFs/ff.c **** 
 728:./Application/FatFs/ff.c **** 
 729:./Application/FatFs/ff.c **** static
 730:./Application/FatFs/ff.c **** FRESULT dec_lock (	/* Decrement object open counter */
 731:./Application/FatFs/ff.c **** 	UINT i			/* Semaphore index (1..) */
 732:./Application/FatFs/ff.c **** )
 733:./Application/FatFs/ff.c **** {
 734:./Application/FatFs/ff.c **** 	WORD n;
 735:./Application/FatFs/ff.c **** 	FRESULT res;
 736:./Application/FatFs/ff.c **** 
 737:./Application/FatFs/ff.c **** 
 738:./Application/FatFs/ff.c **** 	if (--i < _FS_LOCK) {	/* Shift index number origin from 0 */
 739:./Application/FatFs/ff.c **** 		n = Files[i].ctr;
 740:./Application/FatFs/ff.c **** 		if (n == 0x100) n = 0;		/* If write mode open, delete the entry */
 741:./Application/FatFs/ff.c **** 		if (n) n--;					/* Decrement read mode open count */
 742:./Application/FatFs/ff.c **** 		Files[i].ctr = n;
 743:./Application/FatFs/ff.c **** 		if (!n) Files[i].fs = 0;	/* Delete the entry if open count gets zero */
 744:./Application/FatFs/ff.c **** 		res = FR_OK;
 745:./Application/FatFs/ff.c **** 	} else {
 746:./Application/FatFs/ff.c **** 		res = FR_INT_ERR;			/* Invalid index nunber */
 747:./Application/FatFs/ff.c **** 	}
 748:./Application/FatFs/ff.c **** 	return res;
 749:./Application/FatFs/ff.c **** }
 750:./Application/FatFs/ff.c **** 
 751:./Application/FatFs/ff.c **** 
 752:./Application/FatFs/ff.c **** static
 753:./Application/FatFs/ff.c **** void clear_lock (	/* Clear lock entries of the volume */
 754:./Application/FatFs/ff.c **** 	FATFS *fs
 755:./Application/FatFs/ff.c **** )
 756:./Application/FatFs/ff.c **** {
 757:./Application/FatFs/ff.c **** 	UINT i;
 758:./Application/FatFs/ff.c **** 
 759:./Application/FatFs/ff.c **** 	for (i = 0; i < _FS_LOCK; i++) {
 760:./Application/FatFs/ff.c **** 		if (Files[i].fs == fs) Files[i].fs = 0;
 761:./Application/FatFs/ff.c **** 	}
 762:./Application/FatFs/ff.c **** }
 763:./Application/FatFs/ff.c **** #endif
