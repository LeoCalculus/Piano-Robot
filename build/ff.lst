 141:./ThirdParty/FatFs/ff.c **** /* Reentrancy related */
 142:./ThirdParty/FatFs/ff.c **** #if _FS_REENTRANT
 143:./ThirdParty/FatFs/ff.c **** #if _USE_LFN == 1
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccLX7nbq.s 			page 4


 144:./ThirdParty/FatFs/ff.c **** #error Static LFN work area cannot be used at thread-safe configuration
 145:./ThirdParty/FatFs/ff.c **** #endif
 146:./ThirdParty/FatFs/ff.c **** #define	ENTER_FF(fs)		{ if (!lock_fs(fs)) return FR_TIMEOUT; }
 147:./ThirdParty/FatFs/ff.c **** #define	LEAVE_FF(fs, res)	{ unlock_fs(fs, res); return res; }
 148:./ThirdParty/FatFs/ff.c **** #else
 149:./ThirdParty/FatFs/ff.c **** #define	ENTER_FF(fs)
 150:./ThirdParty/FatFs/ff.c **** #define LEAVE_FF(fs, res)	return res
 151:./ThirdParty/FatFs/ff.c **** #endif
 152:./ThirdParty/FatFs/ff.c **** 
 153:./ThirdParty/FatFs/ff.c **** #define	ABORT(fs, res)		{ fp->err = (BYTE)(res); LEAVE_FF(fs, res); }
 154:./ThirdParty/FatFs/ff.c **** 
 155:./ThirdParty/FatFs/ff.c **** 
 156:./ThirdParty/FatFs/ff.c **** /* Definitions of sector size */
 157:./ThirdParty/FatFs/ff.c **** #if (_MAX_SS < _MIN_SS) || (_MAX_SS != 512 && _MAX_SS != 1024 && _MAX_SS != 2048 && _MAX_SS != 4096
 158:./ThirdParty/FatFs/ff.c **** #error Wrong sector size configuration
 159:./ThirdParty/FatFs/ff.c **** #endif
 160:./ThirdParty/FatFs/ff.c **** #if _MAX_SS == _MIN_SS
 161:./ThirdParty/FatFs/ff.c **** #define	SS(fs)	((UINT)_MAX_SS)	/* Fixed sector size */
 162:./ThirdParty/FatFs/ff.c **** #else
 163:./ThirdParty/FatFs/ff.c **** #define	SS(fs)	((fs)->ssize)	/* Variable sector size */
 164:./ThirdParty/FatFs/ff.c **** #endif
 165:./ThirdParty/FatFs/ff.c **** 
 166:./ThirdParty/FatFs/ff.c **** 
 167:./ThirdParty/FatFs/ff.c **** /* Timestamp feature */
 168:./ThirdParty/FatFs/ff.c **** #if _FS_NORTC == 1
 169:./ThirdParty/FatFs/ff.c **** #if _NORTC_YEAR < 1980 || _NORTC_YEAR > 2107 || _NORTC_MON < 1 || _NORTC_MON > 12 || _NORTC_MDAY < 
 170:./ThirdParty/FatFs/ff.c **** #error Invalid _FS_NORTC settings
 171:./ThirdParty/FatFs/ff.c **** #endif
 172:./ThirdParty/FatFs/ff.c **** #define GET_FATTIME()	((DWORD)(_NORTC_YEAR - 1980) << 25 | (DWORD)_NORTC_MON << 21 | (DWORD)_NORTC_
 173:./ThirdParty/FatFs/ff.c **** #else
 174:./ThirdParty/FatFs/ff.c **** #define GET_FATTIME()	get_fattime()
 175:./ThirdParty/FatFs/ff.c **** #endif
 176:./ThirdParty/FatFs/ff.c **** 
 177:./ThirdParty/FatFs/ff.c **** 
 178:./ThirdParty/FatFs/ff.c **** /* File access control feature */
 179:./ThirdParty/FatFs/ff.c **** #if _FS_LOCK
 180:./ThirdParty/FatFs/ff.c **** #if _FS_READONLY
 181:./ThirdParty/FatFs/ff.c **** #error _FS_LOCK must be 0 at read-only configuration
 182:./ThirdParty/FatFs/ff.c **** #endif
 183:./ThirdParty/FatFs/ff.c **** typedef struct {
 184:./ThirdParty/FatFs/ff.c **** 	FATFS *fs;		/* Object ID 1, volume (NULL:blank entry) */
 185:./ThirdParty/FatFs/ff.c **** 	DWORD clu;		/* Object ID 2, directory (0:root) */
 186:./ThirdParty/FatFs/ff.c **** 	WORD idx;		/* Object ID 3, directory index */
 187:./ThirdParty/FatFs/ff.c **** 	WORD ctr;		/* Object open counter, 0:none, 0x01..0xFF:read mode open count, 0x100:write mode */
 188:./ThirdParty/FatFs/ff.c **** } FILESEM;
 189:./ThirdParty/FatFs/ff.c **** #endif
