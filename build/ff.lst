1843:./Application/FatFs/ff.c **** WCHAR get_achar (		/* Get a character and advances ptr 1 or 2 */
1844:./Application/FatFs/ff.c **** 	const TCHAR** ptr	/* Pointer to pointer to the SBCS/DBCS/Unicode string */
1845:./Application/FatFs/ff.c **** )
1846:./Application/FatFs/ff.c **** {
1847:./Application/FatFs/ff.c **** 	WCHAR chr;
1848:./Application/FatFs/ff.c **** 
1849:./Application/FatFs/ff.c **** #if !_LFN_UNICODE
1850:./Application/FatFs/ff.c **** 	chr = (BYTE)*(*ptr)++;					/* Get a byte */
