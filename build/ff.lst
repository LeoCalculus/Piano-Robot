2881:./ThirdParty/FatFs/ff.c **** FRESULT f_sync (
2882:./ThirdParty/FatFs/ff.c **** 	FIL* fp		/* Pointer to the file object */
2883:./ThirdParty/FatFs/ff.c **** )
2884:./ThirdParty/FatFs/ff.c **** {
2885:./ThirdParty/FatFs/ff.c **** 	FRESULT res;
2886:./ThirdParty/FatFs/ff.c **** 	DWORD tm;
