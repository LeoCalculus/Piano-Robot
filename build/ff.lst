2950:./Application/FatFs/ff.c **** #endif
2951:./Application/FatFs/ff.c **** 				fp->fs = 0;				/* Invalidate file object */
2952:./Application/FatFs/ff.c **** #if _FS_REENTRANT
2953:./Application/FatFs/ff.c **** 			unlock_fs(fs, FR_OK);		/* Unlock volume */
2954:./Application/FatFs/ff.c **** #endif
2955:./Application/FatFs/ff.c **** 		}
2956:./Application/FatFs/ff.c **** 	}
