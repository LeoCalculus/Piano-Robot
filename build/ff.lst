1327:./ThirdParty/FatFs/Src/ff.c **** 	DWORD val, scl, ctr;
1328:./ThirdParty/FatFs/Src/ff.c **** 
1329:./ThirdParty/FatFs/Src/ff.c **** 
1330:./ThirdParty/FatFs/Src/ff.c **** 	clst -= 2;	/* The first bit in the bitmap corresponds to cluster #2 */
1331:./ThirdParty/FatFs/Src/ff.c **** 	if (clst >= fs->n_fatent - 2) clst = 0;
1332:./ThirdParty/FatFs/Src/ff.c **** 	scl = val = clst; ctr = 0;
1333:./ThirdParty/FatFs/Src/ff.c **** 	for (;;) {
1334:./ThirdParty/FatFs/Src/ff.c **** 		if (move_window(fs, fs->bitbase + val / 8 / SS(fs)) != FR_OK) return 0xFFFFFFFF;
1335:./ThirdParty/FatFs/Src/ff.c **** 		i = val / 8 % SS(fs); bm = 1 << (val % 8);
1336:./ThirdParty/FatFs/Src/ff.c **** 		do {
1337:./ThirdParty/FatFs/Src/ff.c **** 			do {
1338:./ThirdParty/FatFs/Src/ff.c **** 				bv = fs->win[i] & bm; bm <<= 1;		/* Get bit value */
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccTDbepL.s 			page 29


1339:./ThirdParty/FatFs/Src/ff.c **** 				if (++val >= fs->n_fatent - 2) {	/* Next cluster (with wrap-around) */
1340:./ThirdParty/FatFs/Src/ff.c **** 					val = 0; bm = 0; i = SS(fs);
1341:./ThirdParty/FatFs/Src/ff.c **** 				}
1342:./ThirdParty/FatFs/Src/ff.c **** 				if (bv == 0) {	/* Is it a free cluster? */
1343:./ThirdParty/FatFs/Src/ff.c **** 					if (++ctr == ncl) return scl + 2;	/* Check if run length is sufficient for required */
1344:./ThirdParty/FatFs/Src/ff.c **** 				} else {
1345:./ThirdParty/FatFs/Src/ff.c **** 					scl = val; ctr = 0;		/* Encountered a cluster in-use, restart to scan */
1346:./ThirdParty/FatFs/Src/ff.c **** 				}
1347:./ThirdParty/FatFs/Src/ff.c **** 				if (val == clst) return 0;	/* All cluster scanned? */
1348:./ThirdParty/FatFs/Src/ff.c **** 			} while (bm != 0);
1349:./ThirdParty/FatFs/Src/ff.c **** 			bm = 1;
1350:./ThirdParty/FatFs/Src/ff.c **** 		} while (++i < SS(fs));
1351:./ThirdParty/FatFs/Src/ff.c **** 	}
1352:./ThirdParty/FatFs/Src/ff.c **** }
