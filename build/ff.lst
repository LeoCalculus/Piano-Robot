 768:./ThirdParty/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 769:./ThirdParty/FatFs/ff.c **** /* Move/Flush disk access window in the file system object               */
 770:./ThirdParty/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 771:./ThirdParty/FatFs/ff.c **** #if !_FS_READONLY
 772:./ThirdParty/FatFs/ff.c **** static
 773:./ThirdParty/FatFs/ff.c **** FRESULT sync_window (
 774:./ThirdParty/FatFs/ff.c **** 	FATFS* fs		/* File system object */
 775:./ThirdParty/FatFs/ff.c **** )
 776:./ThirdParty/FatFs/ff.c **** {
 777:./ThirdParty/FatFs/ff.c **** 	DWORD wsect;
 778:./ThirdParty/FatFs/ff.c **** 	UINT nf;
 779:./ThirdParty/FatFs/ff.c **** 	FRESULT res = FR_OK;
 780:./ThirdParty/FatFs/ff.c **** 
 781:./ThirdParty/FatFs/ff.c **** 
 782:./ThirdParty/FatFs/ff.c **** 	if (fs->wflag) {	/* Write back the sector if it is dirty */
 783:./ThirdParty/FatFs/ff.c **** 		wsect = fs->winsect;	/* Current sector number */
 784:./ThirdParty/FatFs/ff.c **** 		if (disk_write(fs->drv, fs->win.d8, wsect, 1) != RES_OK) {
 785:./ThirdParty/FatFs/ff.c **** 			res = FR_DISK_ERR;
 786:./ThirdParty/FatFs/ff.c **** 		} else {
 787:./ThirdParty/FatFs/ff.c **** 			fs->wflag = 0;
 788:./ThirdParty/FatFs/ff.c **** 			if (wsect - fs->fatbase < fs->fsize) {		/* Is it in the FAT area? */
 789:./ThirdParty/FatFs/ff.c **** 				for (nf = fs->n_fats; nf >= 2; nf--) {	/* Reflect the change to all FAT copies */
 790:./ThirdParty/FatFs/ff.c **** 					wsect += fs->fsize;
 791:./ThirdParty/FatFs/ff.c **** 					disk_write(fs->drv, fs->win.d8, wsect, 1);
 792:./ThirdParty/FatFs/ff.c **** 				}
 793:./ThirdParty/FatFs/ff.c **** 			}
 794:./ThirdParty/FatFs/ff.c **** 		}
 795:./ThirdParty/FatFs/ff.c **** 	}
 796:./ThirdParty/FatFs/ff.c **** 	return res;
 797:./ThirdParty/FatFs/ff.c **** }
 798:./ThirdParty/FatFs/ff.c **** #endif
 799:./ThirdParty/FatFs/ff.c **** 
 800:./ThirdParty/FatFs/ff.c **** 
 801:./ThirdParty/FatFs/ff.c **** static
 802:./ThirdParty/FatFs/ff.c **** FRESULT move_window (
 803:./ThirdParty/FatFs/ff.c **** 	FATFS* fs,		/* File system object */
 804:./ThirdParty/FatFs/ff.c **** 	DWORD sector	/* Sector number to make appearance in the fs->win[].d8 */
 805:./ThirdParty/FatFs/ff.c **** )
 806:./ThirdParty/FatFs/ff.c **** {
 807:./ThirdParty/FatFs/ff.c **** 	FRESULT res = FR_OK;
 808:./ThirdParty/FatFs/ff.c **** 
 809:./ThirdParty/FatFs/ff.c **** 
 810:./ThirdParty/FatFs/ff.c **** 	if (sector != fs->winsect) {	/* Window offset changed? */
 811:./ThirdParty/FatFs/ff.c **** #if !_FS_READONLY
 812:./ThirdParty/FatFs/ff.c **** 		res = sync_window(fs);		/* Write-back changes */
 813:./ThirdParty/FatFs/ff.c **** #endif
 814:./ThirdParty/FatFs/ff.c **** 		if (res == FR_OK) {			/* Fill sector window with new data */
 815:./ThirdParty/FatFs/ff.c **** 			if (disk_read(fs->drv, fs->win.d8, sector, 1) != RES_OK) {
 816:./ThirdParty/FatFs/ff.c **** 				sector = 0xFFFFFFFF;	/* Invalidate window if data is not reliable */
 817:./ThirdParty/FatFs/ff.c **** 				res = FR_DISK_ERR;
 818:./ThirdParty/FatFs/ff.c **** 			}
 819:./ThirdParty/FatFs/ff.c **** 			fs->winsect = sector;
 820:./ThirdParty/FatFs/ff.c **** 		}
 821:./ThirdParty/FatFs/ff.c **** 	}
 822:./ThirdParty/FatFs/ff.c **** 	return res;
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccLX7nbq.s 			page 19


 823:./ThirdParty/FatFs/ff.c **** }
