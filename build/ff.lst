2121:./ThirdParty/FatFs/ff.c **** /* Follow a file path                                                    */
2122:./ThirdParty/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
2123:./ThirdParty/FatFs/ff.c **** 
2124:./ThirdParty/FatFs/ff.c **** static
2125:./ThirdParty/FatFs/ff.c **** FRESULT follow_path (	/* FR_OK(0): successful, !=0: error code */
2126:./ThirdParty/FatFs/ff.c **** 	DIR* dp,			/* Directory object to return last directory and found object */
2127:./ThirdParty/FatFs/ff.c **** 	const TCHAR* path	/* Full-path string to find a file or directory */
2128:./ThirdParty/FatFs/ff.c **** )
2129:./ThirdParty/FatFs/ff.c **** {
2130:./ThirdParty/FatFs/ff.c **** 	FRESULT res;
2131:./ThirdParty/FatFs/ff.c **** 	BYTE *dir, ns;
2132:./ThirdParty/FatFs/ff.c **** 
2133:./ThirdParty/FatFs/ff.c **** 
2134:./ThirdParty/FatFs/ff.c **** #if _FS_RPATH
2135:./ThirdParty/FatFs/ff.c **** 	if (*path == '/' || *path == '\\') {	/* There is a heading separator */
2136:./ThirdParty/FatFs/ff.c **** 		path++;	dp->sclust = 0;				/* Strip it and start from the root directory */
2137:./ThirdParty/FatFs/ff.c **** 	} else {								/* No heading separator */
2138:./ThirdParty/FatFs/ff.c **** 		dp->sclust = dp->fs->cdir;			/* Start from the current directory */
2139:./ThirdParty/FatFs/ff.c **** 	}
2140:./ThirdParty/FatFs/ff.c **** #else
2141:./ThirdParty/FatFs/ff.c **** 	if (*path == '/' || *path == '\\')		/* Strip heading separator if exist */
2142:./ThirdParty/FatFs/ff.c **** 		path++;
2143:./ThirdParty/FatFs/ff.c **** 	dp->sclust = 0;							/* Always start from the root directory */
2144:./ThirdParty/FatFs/ff.c **** #endif
2145:./ThirdParty/FatFs/ff.c **** 
2146:./ThirdParty/FatFs/ff.c **** 	if ((UINT)*path < ' ') {				/* Null path name is the origin directory itself */
2147:./ThirdParty/FatFs/ff.c **** 		res = dir_sdi(dp, 0);
2148:./ThirdParty/FatFs/ff.c **** 		dp->dir = 0;
2149:./ThirdParty/FatFs/ff.c **** 	} else {								/* Follow path */
2150:./ThirdParty/FatFs/ff.c **** 		for (;;) {
2151:./ThirdParty/FatFs/ff.c **** 			res = create_name(dp, &path);	/* Get a segment name of the path */
2152:./ThirdParty/FatFs/ff.c **** 			if (res != FR_OK) break;
2153:./ThirdParty/FatFs/ff.c **** 			res = dir_find(dp);				/* Find an object with the sagment name */
2154:./ThirdParty/FatFs/ff.c **** 			ns = dp->fn[NSFLAG];
2155:./ThirdParty/FatFs/ff.c **** 			if (res != FR_OK) {				/* Failed to find the object */
2156:./ThirdParty/FatFs/ff.c **** 				if (res == FR_NO_FILE) {	/* Object is not found */
2157:./ThirdParty/FatFs/ff.c **** 					if (_FS_RPATH && (ns & NS_DOT)) {	/* If dot entry is not exist, */
2158:./ThirdParty/FatFs/ff.c **** 						dp->sclust = 0; dp->dir = 0;	/* it is the root directory and stay there */
2159:./ThirdParty/FatFs/ff.c **** 						if (!(ns & NS_LAST)) continue;	/* Continue to follow if not last segment */
2160:./ThirdParty/FatFs/ff.c **** 						res = FR_OK;					/* Ended at the root directroy. Function completed. */
2161:./ThirdParty/FatFs/ff.c **** 					} else {							/* Could not find the object */
2162:./ThirdParty/FatFs/ff.c **** 						if (!(ns & NS_LAST)) res = FR_NO_PATH;	/* Adjust error code if not last segment */
2163:./ThirdParty/FatFs/ff.c **** 					}
2164:./ThirdParty/FatFs/ff.c **** 				}
