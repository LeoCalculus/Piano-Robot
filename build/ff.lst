 945:./Application/FatFs/ff.c **** #if !_FS_READONLY
 946:./Application/FatFs/ff.c **** FRESULT put_fat (
 947:./Application/FatFs/ff.c **** 	FATFS* fs,	/* File system object */
 948:./Application/FatFs/ff.c **** 	DWORD clst,	/* FAT index number (cluster number) to be changed */
 949:./Application/FatFs/ff.c **** 	DWORD val	/* New value to be set to the entry */
 950:./Application/FatFs/ff.c **** )
 951:./Application/FatFs/ff.c **** {
 952:./Application/FatFs/ff.c **** 	UINT bc;
 953:./Application/FatFs/ff.c **** 	BYTE *p;
 954:./Application/FatFs/ff.c **** 	FRESULT res;
 955:./Application/FatFs/ff.c **** 
 956:./Application/FatFs/ff.c **** 
 957:./Application/FatFs/ff.c **** 	if (clst < 2 || clst >= fs->n_fatent) {	/* Check range */
 958:./Application/FatFs/ff.c **** 		res = FR_INT_ERR;
 959:./Application/FatFs/ff.c **** 
 960:./Application/FatFs/ff.c **** 	} else {
 961:./Application/FatFs/ff.c **** 		switch (fs->fs_type) {
 962:./Application/FatFs/ff.c **** 		case FS_FAT12 :
 963:./Application/FatFs/ff.c **** 			bc = (UINT)clst; bc += bc / 2;
 964:./Application/FatFs/ff.c **** 			res = move_window(fs, fs->fatbase + (bc / SS(fs)));
 965:./Application/FatFs/ff.c **** 			if (res != FR_OK) break;
