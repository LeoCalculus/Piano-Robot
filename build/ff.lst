2906:./ThirdParty/FatFs/ff.c **** 				ST_DWORD(dir + DIR_FileSize, fp->fsize);	/* Update file size */
2907:./ThirdParty/FatFs/ff.c **** 				st_clust(dir, fp->sclust);					/* Update start cluster */
