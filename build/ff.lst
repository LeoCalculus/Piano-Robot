2144:./Application/FatFs/ff.c **** #endif
2145:./Application/FatFs/ff.c **** 
2146:./Application/FatFs/ff.c **** 	if ((UINT)*path < ' ') {				/* Null path name is the origin directory itself */
2147:./Application/FatFs/ff.c **** 		res = dir_sdi(dp, 0);
