1865:./Application/FatFs/ff.c **** int pattern_matching (	/* Return value: 0:mismatched, 1:matched */
1866:./Application/FatFs/ff.c **** 	const TCHAR* pat,	/* Matching pattern */
1867:./Application/FatFs/ff.c **** 	const TCHAR* nam,	/* String to be tested */
1868:./Application/FatFs/ff.c **** 	int skip,			/* Number of pre-skip chars (number of ?s) */
1869:./Application/FatFs/ff.c **** 	int inf				/* Infinite search (* specified) */
1870:./Application/FatFs/ff.c **** )
1871:./Application/FatFs/ff.c **** {
1872:./Application/FatFs/ff.c **** 	const TCHAR *pp, *np;
1873:./Application/FatFs/ff.c **** 	WCHAR pc, nc;
1874:./Application/FatFs/ff.c **** 	int nm, nx;
1875:./Application/FatFs/ff.c **** 
1876:./Application/FatFs/ff.c **** 
1877:./Application/FatFs/ff.c **** 	while (skip--) {				/* Pre-skip name chars */
1878:./Application/FatFs/ff.c **** 		if (!get_achar(&nam)) return 0;	/* Branch mismatched if less name chars */
1879:./Application/FatFs/ff.c **** 	}
1880:./Application/FatFs/ff.c **** 	if (!*pat && inf) return 1;		/* (short circuit) */
1881:./Application/FatFs/ff.c **** 
1882:./Application/FatFs/ff.c **** 	do {
1883:./Application/FatFs/ff.c **** 		pp = pat; np = nam;			/* Top of pattern and name to match */
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccJzsbqh.s 			page 42


1884:./Application/FatFs/ff.c **** 		for (;;) {
1885:./Application/FatFs/ff.c **** 			if (*pp == '?' || *pp == '*') {	/* Wildcard? */
1886:./Application/FatFs/ff.c **** 				nm = nx = 0;
1887:./Application/FatFs/ff.c **** 				do {				/* Analyze the wildcard chars */
1888:./Application/FatFs/ff.c **** 					if (*pp++ == '?') nm++; else nx = 1;
1889:./Application/FatFs/ff.c **** 				} while (*pp == '?' || *pp == '*');
1890:./Application/FatFs/ff.c **** 				if (pattern_matching(pp, np, nm, nx)) return 1;	/* Test new branch (recurs upto number of wildc
1891:./Application/FatFs/ff.c **** 				nc = *np; break;	/* Branch mismatched */
1892:./Application/FatFs/ff.c **** 			}
1893:./Application/FatFs/ff.c **** 			pc = get_achar(&pp);	/* Get a pattern char */
1894:./Application/FatFs/ff.c **** 			nc = get_achar(&np);	/* Get a name char */
1895:./Application/FatFs/ff.c **** 			if (pc != nc) break;	/* Branch mismatched? */
1896:./Application/FatFs/ff.c **** 			if (!pc) return 1;		/* Branch matched? (matched at end of both strings) */
1897:./Application/FatFs/ff.c **** 		}
1898:./Application/FatFs/ff.c **** 		get_achar(&nam);			/* nam++ */
1899:./Application/FatFs/ff.c **** 	} while (inf && nc);			/* Retry until end of name if infinite search is specified */
1900:./Application/FatFs/ff.c **** 
1901:./Application/FatFs/ff.c **** 	return 0;
1902:./Application/FatFs/ff.c **** }
