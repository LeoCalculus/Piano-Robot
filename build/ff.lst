 828:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 829:./Application/FatFs/ff.c **** /* Synchronize file system and strage device                             */
 830:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 831:./Application/FatFs/ff.c **** #if !_FS_READONLY
 832:./Application/FatFs/ff.c **** static
 833:./Application/FatFs/ff.c **** FRESULT sync_fs (	/* FR_OK: successful, FR_DISK_ERR: failed */
 834:./Application/FatFs/ff.c **** 	FATFS* fs		/* File system object */
 835:./Application/FatFs/ff.c **** )
 836:./Application/FatFs/ff.c **** {
 837:./Application/FatFs/ff.c **** 	FRESULT res;
 838:./Application/FatFs/ff.c **** 
 839:./Application/FatFs/ff.c **** 
 840:./Application/FatFs/ff.c **** 	res = sync_window(fs);
 841:./Application/FatFs/ff.c **** 	if (res == FR_OK) {
 842:./Application/FatFs/ff.c **** 		/* Update FSINFO sector if needed */
 843:./Application/FatFs/ff.c **** 		if (fs->fs_type == FS_FAT32 && fs->fsi_flag == 1) {
 844:./Application/FatFs/ff.c **** 			/* Create FSINFO structure */
 845:./Application/FatFs/ff.c **** 			mem_set(fs->win.d8, 0, SS(fs));
 846:./Application/FatFs/ff.c **** 			ST_WORD(fs->win.d8 + BS_55AA, 0xAA55);
 847:./Application/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_LeadSig, 0x41615252);
 848:./Application/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_StrucSig, 0x61417272);
 849:./Application/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_Free_Count, fs->free_clust);
 850:./Application/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_Nxt_Free, fs->last_clust);
 851:./Application/FatFs/ff.c **** 			/* Write it into the FSINFO sector */
 852:./Application/FatFs/ff.c **** 			fs->winsect = fs->volbase + 1;
 853:./Application/FatFs/ff.c **** 			disk_write(fs->drv, fs->win.d8, fs->winsect, 1);
 854:./Application/FatFs/ff.c **** 			fs->fsi_flag = 0;
 855:./Application/FatFs/ff.c **** 		}
 856:./Application/FatFs/ff.c **** 		/* Make sure that no pending write process in the physical drive */
 857:./Application/FatFs/ff.c **** 		if (disk_ioctl(fs->drv, CTRL_SYNC, 0) != RES_OK)
 858:./Application/FatFs/ff.c **** 			res = FR_DISK_ERR;
 859:./Application/FatFs/ff.c **** 	}
 860:./Application/FatFs/ff.c **** 
 861:./Application/FatFs/ff.c **** 	return res;
 862:./Application/FatFs/ff.c **** }
 863:./Application/FatFs/ff.c **** #endif
 864:./Application/FatFs/ff.c **** 
