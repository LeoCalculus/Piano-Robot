1359:./ThirdParty/FatFs/Src/ff.c **** static FRESULT change_bitmap (
1360:./ThirdParty/FatFs/Src/ff.c **** 	FATFS* fs,	/* Filesystem object */
1361:./ThirdParty/FatFs/Src/ff.c **** 	DWORD clst,	/* Cluster number to change from */
1362:./ThirdParty/FatFs/Src/ff.c **** 	DWORD ncl,	/* Number of clusters to be changed */
1363:./ThirdParty/FatFs/Src/ff.c **** 	int bv		/* bit value to be set (0 or 1) */
1364:./ThirdParty/FatFs/Src/ff.c **** )
1365:./ThirdParty/FatFs/Src/ff.c **** {
1366:./ThirdParty/FatFs/Src/ff.c **** 	BYTE bm;
