1368:./ThirdParty/FatFs/Src/ff.c **** 	LBA_t sect;
1369:./ThirdParty/FatFs/Src/ff.c **** 
1370:./ThirdParty/FatFs/Src/ff.c **** 
1371:./ThirdParty/FatFs/Src/ff.c **** 	clst -= 2;	/* The first bit corresponds to cluster #2 */
1372:./ThirdParty/FatFs/Src/ff.c **** 	sect = fs->bitbase + clst / 8 / SS(fs);	/* Sector address */
1373:./ThirdParty/FatFs/Src/ff.c **** 	i = clst / 8 % SS(fs);					/* Byte offset in the sector */
1374:./ThirdParty/FatFs/Src/ff.c **** 	bm = 1 << (clst % 8);					/* Bit mask in the byte */
1375:./ThirdParty/FatFs/Src/ff.c **** 	for (;;) {
