 769:./Application/FatFs/ff.c **** /* Move/Flush disk access window in the file system object               */
 770:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 771:./Application/FatFs/ff.c **** #if !_FS_READONLY
 772:./Application/FatFs/ff.c **** static
 773:./Application/FatFs/ff.c **** FRESULT sync_window (
 774:./Application/FatFs/ff.c **** 	FATFS* fs		/* File system object */
 775:./Application/FatFs/ff.c **** )
 776:./Application/FatFs/ff.c **** {
 777:./Application/FatFs/ff.c **** 	DWORD wsect;
 778:./Application/FatFs/ff.c **** 	UINT nf;
 779:./Application/FatFs/ff.c **** 	FRESULT res = FR_OK;
 780:./Application/FatFs/ff.c **** 
 781:./Application/FatFs/ff.c **** 
 782:./Application/FatFs/ff.c **** 	if (fs->wflag) {	/* Write back the sector if it is dirty */
 783:./Application/FatFs/ff.c **** 		wsect = fs->winsect;	/* Current sector number */
 784:./Application/FatFs/ff.c **** 		if (disk_write(fs->drv, fs->win.d8, wsect, 1) != RES_OK) {
 785:./Application/FatFs/ff.c **** 			res = FR_DISK_ERR;
 786:./Application/FatFs/ff.c **** 		} else {
 787:./Application/FatFs/ff.c **** 			fs->wflag = 0;
 788:./Application/FatFs/ff.c **** 			if (wsect - fs->fatbase < fs->fsize) {		/* Is it in the FAT area? */
 789:./Application/FatFs/ff.c **** 				for (nf = fs->n_fats; nf >= 2; nf--) {	/* Reflect the change to all FAT copies */
 790:./Application/FatFs/ff.c **** 					wsect += fs->fsize;
 791:./Application/FatFs/ff.c **** 					disk_write(fs->drv, fs->win.d8, wsect, 1);
 792:./Application/FatFs/ff.c **** 				}
 793:./Application/FatFs/ff.c **** 			}
 794:./Application/FatFs/ff.c **** 		}
 795:./Application/FatFs/ff.c **** 	}
 796:./Application/FatFs/ff.c **** 	return res;
 797:./Application/FatFs/ff.c **** }
 798:./Application/FatFs/ff.c **** #endif
 799:./Application/FatFs/ff.c **** 
 800:./Application/FatFs/ff.c **** 
 801:./Application/FatFs/ff.c **** static
 802:./Application/FatFs/ff.c **** FRESULT move_window (
 803:./Application/FatFs/ff.c **** 	FATFS* fs,		/* File system object */
 804:./Application/FatFs/ff.c **** 	DWORD sector	/* Sector number to make appearance in the fs->win[].d8 */
 805:./Application/FatFs/ff.c **** )
 806:./Application/FatFs/ff.c **** {
 807:./Application/FatFs/ff.c **** 	FRESULT res = FR_OK;
 808:./Application/FatFs/ff.c **** 
 809:./Application/FatFs/ff.c **** 
 810:./Application/FatFs/ff.c **** 	if (sector != fs->winsect) {	/* Window offset changed? */
 811:./Application/FatFs/ff.c **** #if !_FS_READONLY
 812:./Application/FatFs/ff.c **** 		res = sync_window(fs);		/* Write-back changes */
 813:./Application/FatFs/ff.c **** #endif
 814:./Application/FatFs/ff.c **** 		if (res == FR_OK) {			/* Fill sector window with new data */
 815:./Application/FatFs/ff.c **** 			if (disk_read(fs->drv, fs->win.d8, sector, 1) != RES_OK) {
 816:./Application/FatFs/ff.c **** 				sector = 0xFFFFFFFF;	/* Invalidate window if data is not reliable */
 817:./Application/FatFs/ff.c **** 				res = FR_DISK_ERR;
 818:./Application/FatFs/ff.c **** 			}
 819:./Application/FatFs/ff.c **** 			fs->winsect = sector;
 820:./Application/FatFs/ff.c **** 		}
 821:./Application/FatFs/ff.c **** 	}
 822:./Application/FatFs/ff.c **** 	return res;
 823:./Application/FatFs/ff.c **** }
