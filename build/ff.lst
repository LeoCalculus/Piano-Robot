1108:./ThirdParty/FatFs/ff.c **** 	} else {
1109:./ThirdParty/FatFs/ff.c **** 		ncl = (res == FR_DISK_ERR) ? 0xFFFFFFFF : 1;
1110:./ThirdParty/FatFs/ff.c **** 	}
1111:./ThirdParty/FatFs/ff.c **** 
1112:./ThirdParty/FatFs/ff.c **** 	return ncl;		/* Return new cluster number or error code */
1113:./ThirdParty/FatFs/ff.c **** }
