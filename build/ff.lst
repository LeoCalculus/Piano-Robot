1061:./Application/FatFs/ff.c **** #if !_FS_READONLY
1062:./Application/FatFs/ff.c **** static
1063:./Application/FatFs/ff.c **** DWORD create_chain (	/* 0:No free cluster, 1:Internal error, 0xFFFFFFFF:Disk error, >=2:New cluster
1064:./Application/FatFs/ff.c **** 	FATFS* fs,			/* File system object */
1065:./Application/FatFs/ff.c **** 	DWORD clst			/* Cluster# to stretch. 0 means create a new chain. */
1066:./Application/FatFs/ff.c **** )
1067:./Application/FatFs/ff.c **** {
1068:./Application/FatFs/ff.c **** 	DWORD cs, ncl, scl;
1069:./Application/FatFs/ff.c **** 	FRESULT res;
1070:./Application/FatFs/ff.c **** 
1071:./Application/FatFs/ff.c **** 
1072:./Application/FatFs/ff.c **** 	if (clst == 0) {		/* Create a new chain */
