1060:./ThirdParty/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
1061:./ThirdParty/FatFs/ff.c **** #if !_FS_READONLY
1062:./ThirdParty/FatFs/ff.c **** static
1063:./ThirdParty/FatFs/ff.c **** DWORD create_chain (	/* 0:No free cluster, 1:Internal error, 0xFFFFFFFF:Disk error, >=2:New cluster
1064:./ThirdParty/FatFs/ff.c **** 	FATFS* fs,			/* File system object */
1065:./ThirdParty/FatFs/ff.c **** 	DWORD clst			/* Cluster# to stretch. 0 means create a new chain. */
1066:./ThirdParty/FatFs/ff.c **** )
1067:./ThirdParty/FatFs/ff.c **** {
1068:./ThirdParty/FatFs/ff.c **** 	DWORD cs, ncl, scl;
1069:./ThirdParty/FatFs/ff.c **** 	FRESULT res;
1070:./ThirdParty/FatFs/ff.c **** 
1071:./ThirdParty/FatFs/ff.c **** 
1072:./ThirdParty/FatFs/ff.c **** 	if (clst == 0) {		/* Create a new chain */
1073:./ThirdParty/FatFs/ff.c **** 		scl = fs->last_clust;			/* Get suggested start point */
1074:./ThirdParty/FatFs/ff.c **** 		if (!scl || scl >= fs->n_fatent) scl = 1;
1075:./ThirdParty/FatFs/ff.c **** 	}
1076:./ThirdParty/FatFs/ff.c **** 	else {					/* Stretch the current chain */
1077:./ThirdParty/FatFs/ff.c **** 		cs = get_fat(fs, clst);			/* Check the cluster status */
1078:./ThirdParty/FatFs/ff.c **** 		if (cs < 2) return 1;			/* Invalid value */
1079:./ThirdParty/FatFs/ff.c **** 		if (cs == 0xFFFFFFFF) return cs;	/* A disk error occurred */
1080:./ThirdParty/FatFs/ff.c **** 		if (cs < fs->n_fatent) return cs;	/* It is already followed by next cluster */
1081:./ThirdParty/FatFs/ff.c **** 		scl = clst;
1082:./ThirdParty/FatFs/ff.c **** 	}
1083:./ThirdParty/FatFs/ff.c **** 
1084:./ThirdParty/FatFs/ff.c **** 	ncl = scl;				/* Start cluster */
1085:./ThirdParty/FatFs/ff.c **** 	for (;;) {
1086:./ThirdParty/FatFs/ff.c **** 		ncl++;							/* Next cluster */
1087:./ThirdParty/FatFs/ff.c **** 		if (ncl >= fs->n_fatent) {		/* Check wrap around */
1088:./ThirdParty/FatFs/ff.c **** 			ncl = 2;
1089:./ThirdParty/FatFs/ff.c **** 			if (ncl > scl) return 0;	/* No free cluster */
1090:./ThirdParty/FatFs/ff.c **** 		}
1091:./ThirdParty/FatFs/ff.c **** 		cs = get_fat(fs, ncl);			/* Get the cluster status */
1092:./ThirdParty/FatFs/ff.c **** 		if (cs == 0) break;				/* Found a free cluster */
1093:./ThirdParty/FatFs/ff.c **** 		if (cs == 0xFFFFFFFF || cs == 1)/* An error occurred */
1094:./ThirdParty/FatFs/ff.c **** 			return cs;
1095:./ThirdParty/FatFs/ff.c **** 		if (ncl == scl) return 0;		/* No free cluster */
1096:./ThirdParty/FatFs/ff.c **** 	}
1097:./ThirdParty/FatFs/ff.c **** 
1098:./ThirdParty/FatFs/ff.c **** 	res = put_fat(fs, ncl, 0x0FFFFFFF);	/* Mark the new cluster "last link" */
1099:./ThirdParty/FatFs/ff.c **** 	if (res == FR_OK && clst != 0) {
1100:./ThirdParty/FatFs/ff.c **** 		res = put_fat(fs, clst, ncl);	/* Link it to the previous one if needed */
1101:./ThirdParty/FatFs/ff.c **** 	}
1102:./ThirdParty/FatFs/ff.c **** 	if (res == FR_OK) {
1103:./ThirdParty/FatFs/ff.c **** 		fs->last_clust = ncl;			/* Update FSINFO */
1104:./ThirdParty/FatFs/ff.c **** 		if (fs->free_clust != 0xFFFFFFFF) {
1105:./ThirdParty/FatFs/ff.c **** 			fs->free_clust--;
1106:./ThirdParty/FatFs/ff.c **** 			fs->fsi_flag |= 1;
1107:./ThirdParty/FatFs/ff.c **** 		}
