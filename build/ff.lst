1099:./Application/FatFs/ff.c **** 	if (res == FR_OK && clst != 0) {
1100:./Application/FatFs/ff.c **** 		res = put_fat(fs, clst, ncl);	/* Link it to the previous one if needed */
1101:./Application/FatFs/ff.c **** 	}
1102:./Application/FatFs/ff.c **** 	if (res == FR_OK) {
1103:./Application/FatFs/ff.c **** 		fs->last_clust = ncl;			/* Update FSINFO */
1104:./Application/FatFs/ff.c **** 		if (fs->free_clust != 0xFFFFFFFF) {
1105:./Application/FatFs/ff.c **** 			fs->free_clust--;
1106:./Application/FatFs/ff.c **** 			fs->fsi_flag |= 1;
1107:./Application/FatFs/ff.c **** 		}
1108:./Application/FatFs/ff.c **** 	} else {
