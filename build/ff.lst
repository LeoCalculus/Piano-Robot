4400:./ThirdParty/FatFs/ff.c **** 
4401:./ThirdParty/FatFs/ff.c **** 	/* Determine CHS in the table regardless of the drive geometry */
4402:./ThirdParty/FatFs/ff.c **** 	for (n = 16; n < 256 && sz_disk / n / 63 > 1024; n *= 2) ;
