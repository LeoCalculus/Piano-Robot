 867:./Application/FatFs/ff.c **** 
 868:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 869:./Application/FatFs/ff.c **** /* Get sector# from cluster#                                             */
 870:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 871:./Application/FatFs/ff.c **** /* Hidden API for hacks and disk tools */
 872:./Application/FatFs/ff.c **** 
 873:./Application/FatFs/ff.c **** DWORD clust2sect (	/* !=0: Sector number, 0: Failed - invalid cluster# */
 874:./Application/FatFs/ff.c **** 	FATFS* fs,		/* File system object */
 875:./Application/FatFs/ff.c **** 	DWORD clst		/* Cluster# to be converted */
 876:./Application/FatFs/ff.c **** )
 877:./Application/FatFs/ff.c **** {
 878:./Application/FatFs/ff.c **** 	clst -= 2;
 879:./Application/FatFs/ff.c **** 	if (clst >= fs->n_fatent - 2) return 0;		/* Invalid cluster# */
 880:./Application/FatFs/ff.c **** 	return clst * fs->csize + fs->database;
 881:./Application/FatFs/ff.c **** }
