 827:./ThirdParty/FatFs/ff.c **** 
 828:./ThirdParty/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 829:./ThirdParty/FatFs/ff.c **** /* Synchronize file system and strage device                             */
 830:./ThirdParty/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 831:./ThirdParty/FatFs/ff.c **** #if !_FS_READONLY
 832:./ThirdParty/FatFs/ff.c **** static
 833:./ThirdParty/FatFs/ff.c **** FRESULT sync_fs (	/* FR_OK: successful, FR_DISK_ERR: failed */
 834:./ThirdParty/FatFs/ff.c **** 	FATFS* fs		/* File system object */
 835:./ThirdParty/FatFs/ff.c **** )
 836:./ThirdParty/FatFs/ff.c **** {
 837:./ThirdParty/FatFs/ff.c **** 	FRESULT res;
 838:./ThirdParty/FatFs/ff.c **** 
 839:./ThirdParty/FatFs/ff.c **** 
 840:./ThirdParty/FatFs/ff.c **** 	res = sync_window(fs);
 841:./ThirdParty/FatFs/ff.c **** 	if (res == FR_OK) {
 842:./ThirdParty/FatFs/ff.c **** 		/* Update FSINFO sector if needed */
 843:./ThirdParty/FatFs/ff.c **** 		if (fs->fs_type == FS_FAT32 && fs->fsi_flag == 1) {
 844:./ThirdParty/FatFs/ff.c **** 			/* Create FSINFO structure */
 845:./ThirdParty/FatFs/ff.c **** 			mem_set(fs->win.d8, 0, SS(fs));
 846:./ThirdParty/FatFs/ff.c **** 			ST_WORD(fs->win.d8 + BS_55AA, 0xAA55);
 847:./ThirdParty/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_LeadSig, 0x41615252);
 848:./ThirdParty/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_StrucSig, 0x61417272);
 849:./ThirdParty/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_Free_Count, fs->free_clust);
 850:./ThirdParty/FatFs/ff.c **** 			ST_DWORD(fs->win.d8 + FSI_Nxt_Free, fs->last_clust);
 851:./ThirdParty/FatFs/ff.c **** 			/* Write it into the FSINFO sector */
 852:./ThirdParty/FatFs/ff.c **** 			fs->winsect = fs->volbase + 1;
 853:./ThirdParty/FatFs/ff.c **** 			disk_write(fs->drv, fs->win.d8, fs->winsect, 1);
 854:./ThirdParty/FatFs/ff.c **** 			fs->fsi_flag = 0;
 855:./ThirdParty/FatFs/ff.c **** 		}
 856:./ThirdParty/FatFs/ff.c **** 		/* Make sure that no pending write process in the physical drive */
 857:./ThirdParty/FatFs/ff.c **** 		if (disk_ioctl(fs->drv, CTRL_SYNC, 0) != RES_OK)
 858:./ThirdParty/FatFs/ff.c **** 			res = FR_DISK_ERR;
 859:./ThirdParty/FatFs/ff.c **** 	}
 860:./ThirdParty/FatFs/ff.c **** 
 861:./ThirdParty/FatFs/ff.c **** 	return res;
