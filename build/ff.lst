2944:./Application/FatFs/ff.c **** #if _FS_REENTRANT
2945:./Application/FatFs/ff.c **** 			FATFS *fs = fp->fs;
2946:./Application/FatFs/ff.c **** #endif
2947:./Application/FatFs/ff.c **** #if _FS_LOCK
2948:./Application/FatFs/ff.c **** 			res = dec_lock(fp->lockid);	/* Decrement file open counter */
