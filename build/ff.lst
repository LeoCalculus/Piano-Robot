1090:./Application/FatFs/ff.c **** 		}
1091:./Application/FatFs/ff.c **** 		cs = get_fat(fs, ncl);			/* Get the cluster status */
1092:./Application/FatFs/ff.c **** 		if (cs == 0) break;				/* Found a free cluster */
1093:./Application/FatFs/ff.c **** 		if (cs == 0xFFFFFFFF || cs == 1)/* An error occurred */
1094:./Application/FatFs/ff.c **** 			return cs;
