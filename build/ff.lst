 886:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 887:./Application/FatFs/ff.c **** /* FAT access - Read value of a FAT entry                                */
 888:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
 889:./Application/FatFs/ff.c **** /* Hidden API for hacks and disk tools */
 890:./Application/FatFs/ff.c **** 
 891:./Application/FatFs/ff.c **** DWORD get_fat (	/* 0xFFFFFFFF:Disk error, 1:Internal error, 2..0x0FFFFFFF:Cluster status */
 892:./Application/FatFs/ff.c **** 	FATFS* fs,	/* File system object */
 893:./Application/FatFs/ff.c **** 	DWORD clst	/* FAT index number (cluster number) to get the value */
 894:./Application/FatFs/ff.c **** )
 895:./Application/FatFs/ff.c **** {
 896:./Application/FatFs/ff.c **** 	UINT wc, bc;
 897:./Application/FatFs/ff.c **** 	BYTE *p;
 898:./Application/FatFs/ff.c **** 	DWORD val;
 899:./Application/FatFs/ff.c **** 
 900:./Application/FatFs/ff.c **** 
 901:./Application/FatFs/ff.c **** 	if (clst < 2 || clst >= fs->n_fatent) {	/* Check range */
 902:./Application/FatFs/ff.c **** 		val = 1;	/* Internal error */
 903:./Application/FatFs/ff.c **** 
 904:./Application/FatFs/ff.c **** 	} else {
 905:./Application/FatFs/ff.c **** 		val = 0xFFFFFFFF;	/* Default value falls on disk error */
 906:./Application/FatFs/ff.c **** 
 907:./Application/FatFs/ff.c **** 		switch (fs->fs_type) {
 908:./Application/FatFs/ff.c **** 		case FS_FAT12 :
 909:./Application/FatFs/ff.c **** 			bc = (UINT)clst; bc += bc / 2;
