 636:./ThirdParty/FatFs/ff.c **** 
 637:./ThirdParty/FatFs/ff.c **** static
 638:./ThirdParty/FatFs/ff.c **** void unlock_fs (
 639:./ThirdParty/FatFs/ff.c **** 	FATFS* fs,		/* File system object */
 640:./ThirdParty/FatFs/ff.c **** 	FRESULT res		/* Result code to be returned */
 641:./ThirdParty/FatFs/ff.c **** )
 642:./ThirdParty/FatFs/ff.c **** {
