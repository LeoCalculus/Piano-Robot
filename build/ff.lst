 141:./Application/FatFs/ff.c **** /* Reentrancy related */
 142:./Application/FatFs/ff.c **** #if _FS_REENTRANT
 143:./Application/FatFs/ff.c **** #if _USE_LFN == 1
 144:./Application/FatFs/ff.c **** #error Static LFN work area cannot be used at thread-safe configuration
 145:./Application/FatFs/ff.c **** #endif
 146:./Application/FatFs/ff.c **** #define	ENTER_FF(fs)		{ if (!lock_fs(fs)) return FR_TIMEOUT; }
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccJzsbqh.s 			page 4


 147:./Application/FatFs/ff.c **** #define	LEAVE_FF(fs, res)	{ unlock_fs(fs, res); return res; }
 148:./Application/FatFs/ff.c **** #else
 149:./Application/FatFs/ff.c **** #define	ENTER_FF(fs)
 150:./Application/FatFs/ff.c **** #define LEAVE_FF(fs, res)	return res
 151:./Application/FatFs/ff.c **** #endif
 152:./Application/FatFs/ff.c **** 
 153:./Application/FatFs/ff.c **** #define	ABORT(fs, res)		{ fp->err = (BYTE)(res); LEAVE_FF(fs, res); }
