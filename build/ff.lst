  36:./ThirdParty/FatFs/Src/ff.c **** 
  37:./ThirdParty/FatFs/Src/ff.c **** /* Limits and boundaries */
  38:./ThirdParty/FatFs/Src/ff.c **** #define MAX_DIR		0x200000		/* Max size of FAT directory (byte) */
  39:./ThirdParty/FatFs/Src/ff.c **** #define MAX_DIR_EX	0x10000000		/* Max size of exFAT directory (byte) */
  40:./ThirdParty/FatFs/Src/ff.c **** #define MAX_FAT12	0xFF5			/* Max FAT12 clusters (differs from specs, but right for real DOS/Windows
  41:./ThirdParty/FatFs/Src/ff.c **** #define MAX_FAT16	0xFFF5			/* Max FAT16 clusters (differs from specs, but right for real DOS/Window
  42:./ThirdParty/FatFs/Src/ff.c **** #define MAX_FAT32	0x0FFFFFF5		/* Max FAT32 clusters (not defined in specs, practical limit) */
  43:./ThirdParty/FatFs/Src/ff.c **** #define MAX_EXFAT	0x7FFFFFFD		/* Max exFAT clusters (differs from specs, implementation limit) */
  44:./ThirdParty/FatFs/Src/ff.c **** 
  45:./ThirdParty/FatFs/Src/ff.c **** 
  46:./ThirdParty/FatFs/Src/ff.c **** /* Character code support macros */
  47:./ThirdParty/FatFs/Src/ff.c **** #define IsUpper(c)		((c) >= 'A' && (c) <= 'Z')
  48:./ThirdParty/FatFs/Src/ff.c **** #define IsLower(c)		((c) >= 'a' && (c) <= 'z')
  49:./ThirdParty/FatFs/Src/ff.c **** #define IsDigit(c)		((c) >= '0' && (c) <= '9')
  50:./ThirdParty/FatFs/Src/ff.c **** #define IsSeparator(c)	((c) == '/' || (c) == '\\')
  51:./ThirdParty/FatFs/Src/ff.c **** #define IsTerminator(c)	((UINT)(c) < (FF_USE_LFN ? ' ' : '!'))
  52:./ThirdParty/FatFs/Src/ff.c **** #define IsSurrogate(c)	((c) >= 0xD800 && (c) <= 0xDFFF)
  53:./ThirdParty/FatFs/Src/ff.c **** #define IsSurrogateH(c)	((c) >= 0xD800 && (c) <= 0xDBFF)
  54:./ThirdParty/FatFs/Src/ff.c **** #define IsSurrogateL(c)	((c) >= 0xDC00 && (c) <= 0xDFFF)
  55:./ThirdParty/FatFs/Src/ff.c **** 
  56:./ThirdParty/FatFs/Src/ff.c **** 
  57:./ThirdParty/FatFs/Src/ff.c **** /* Additional file access control and file status flags for internal use */
  58:./ThirdParty/FatFs/Src/ff.c **** #define FA_SEEKEND	0x20	/* Seek to end of the file on file open */
  59:./ThirdParty/FatFs/Src/ff.c **** #define FA_MODIFIED	0x40	/* File has been modified */
  60:./ThirdParty/FatFs/Src/ff.c **** #define FA_DIRTY	0x80	/* FIL.buf[] needs to be written-back */
  61:./ThirdParty/FatFs/Src/ff.c **** 
  62:./ThirdParty/FatFs/Src/ff.c **** 
  63:./ThirdParty/FatFs/Src/ff.c **** /* Additional file attribute bits for internal use */
  64:./ThirdParty/FatFs/Src/ff.c **** #define AM_VOL		0x08	/* Volume label */
  65:./ThirdParty/FatFs/Src/ff.c **** #define AM_LFN		0x0F	/* LFN entry */
  66:./ThirdParty/FatFs/Src/ff.c **** #define AM_MASK		0x3F	/* Mask of defined bits in FAT */
  67:./ThirdParty/FatFs/Src/ff.c **** #define AM_MASKX	0x37	/* Mask of defined bits in exFAT */
  68:./ThirdParty/FatFs/Src/ff.c **** 
  69:./ThirdParty/FatFs/Src/ff.c **** 
  70:./ThirdParty/FatFs/Src/ff.c **** /* Name status flags in fn[11] */
  71:./ThirdParty/FatFs/Src/ff.c **** #define NSFLAG		11		/* Index of the name status byte */
  72:./ThirdParty/FatFs/Src/ff.c **** #define NS_LOSS		0x01	/* Out of 8.3 format */
  73:./ThirdParty/FatFs/Src/ff.c **** #define NS_LFN		0x02	/* Force to create LFN entry */
  74:./ThirdParty/FatFs/Src/ff.c **** #define NS_LAST		0x04	/* Last segment */
  75:./ThirdParty/FatFs/Src/ff.c **** #define NS_BODY		0x08	/* Lower case flag (body) */
  76:./ThirdParty/FatFs/Src/ff.c **** #define NS_EXT		0x10	/* Lower case flag (ext) */
  77:./ThirdParty/FatFs/Src/ff.c **** #define NS_DOT		0x20	/* Dot entry */
  78:./ThirdParty/FatFs/Src/ff.c **** #define NS_NOLFN	0x40	/* Do not find LFN */
  79:./ThirdParty/FatFs/Src/ff.c **** #define NS_NONAME	0x80	/* Not followed */
  80:./ThirdParty/FatFs/Src/ff.c **** 
  81:./ThirdParty/FatFs/Src/ff.c **** 
  82:./ThirdParty/FatFs/Src/ff.c **** /* exFAT directory entry types */
