1315:./ThirdParty/FatFs/Src/ff.c **** /*--------------------------------------*/
1316:./ThirdParty/FatFs/Src/ff.c **** /* Find a contiguous free cluster block */
1317:./ThirdParty/FatFs/Src/ff.c **** /*--------------------------------------*/
1318:./ThirdParty/FatFs/Src/ff.c **** 
1319:./ThirdParty/FatFs/Src/ff.c **** static DWORD find_bitmap (	/* 0:Not found, 2..:Cluster block found, 0xFFFFFFFF:Disk error */
1320:./ThirdParty/FatFs/Src/ff.c **** 	FATFS* fs,	/* Filesystem object */
1321:./ThirdParty/FatFs/Src/ff.c **** 	DWORD clst,	/* Cluster number to scan from */
1322:./ThirdParty/FatFs/Src/ff.c **** 	DWORD ncl	/* Number of contiguous clusters to find (1..) */
1323:./ThirdParty/FatFs/Src/ff.c **** )
1324:./ThirdParty/FatFs/Src/ff.c **** {
1325:./ThirdParty/FatFs/Src/ff.c **** 	BYTE bm, bv;
