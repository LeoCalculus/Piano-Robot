6935:./ThirdParty/FatFs/Src/ff.c **** 
6936:./ThirdParty/FatFs/Src/ff.c **** static int ilog10 (double n)	/* Calculate log10(n) in integer output */
6937:./ThirdParty/FatFs/Src/ff.c **** {
6938:./ThirdParty/FatFs/Src/ff.c **** 	int rv = 0;
6939:./ThirdParty/FatFs/Src/ff.c **** 
6940:./ThirdParty/FatFs/Src/ff.c **** 	while (n >= 10) {	/* Decimate digit in right shift */
6941:./ThirdParty/FatFs/Src/ff.c **** 		if (n >= 100000) {
6942:./ThirdParty/FatFs/Src/ff.c **** 			n /= 100000; rv += 5;
6943:./ThirdParty/FatFs/Src/ff.c **** 		} else {
6944:./ThirdParty/FatFs/Src/ff.c **** 			n /= 10; rv++;
6945:./ThirdParty/FatFs/Src/ff.c **** 		}
6946:./ThirdParty/FatFs/Src/ff.c **** 	}
6947:./ThirdParty/FatFs/Src/ff.c **** 	while (n < 1) {		/* Decimate digit in left shift */
6948:./ThirdParty/FatFs/Src/ff.c **** 		if (n < 0.00001) {
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccTDbepL.s 			page 326


6949:./ThirdParty/FatFs/Src/ff.c **** 			n *= 100000; rv -= 5;
6950:./ThirdParty/FatFs/Src/ff.c **** 		} else {
6951:./ThirdParty/FatFs/Src/ff.c **** 			n *= 10; rv--;
6952:./ThirdParty/FatFs/Src/ff.c **** 		}
6953:./ThirdParty/FatFs/Src/ff.c **** 	}
6954:./ThirdParty/FatFs/Src/ff.c **** 	return rv;
6955:./ThirdParty/FatFs/Src/ff.c **** }
6956:./ThirdParty/FatFs/Src/ff.c **** 
6957:./ThirdParty/FatFs/Src/ff.c **** 
6958:./ThirdParty/FatFs/Src/ff.c **** static double i10x (int n)	/* Calculate 10^n in integer input */
6959:./ThirdParty/FatFs/Src/ff.c **** {
6960:./ThirdParty/FatFs/Src/ff.c **** 	double rv = 1;
6961:./ThirdParty/FatFs/Src/ff.c **** 
6962:./ThirdParty/FatFs/Src/ff.c **** 	while (n > 0) {		/* Left shift */
6963:./ThirdParty/FatFs/Src/ff.c **** 		if (n >= 5) {
6964:./ThirdParty/FatFs/Src/ff.c **** 			rv *= 100000; n -= 5;
6965:./ThirdParty/FatFs/Src/ff.c **** 		} else {
6966:./ThirdParty/FatFs/Src/ff.c **** 			rv *= 10; n--;
6967:./ThirdParty/FatFs/Src/ff.c **** 		}
6968:./ThirdParty/FatFs/Src/ff.c **** 	}
6969:./ThirdParty/FatFs/Src/ff.c **** 	while (n < 0) {		/* Right shift */
6970:./ThirdParty/FatFs/Src/ff.c **** 		if (n <= -5) {
6971:./ThirdParty/FatFs/Src/ff.c **** 			rv /= 100000; n += 5;
6972:./ThirdParty/FatFs/Src/ff.c **** 		} else {
6973:./ThirdParty/FatFs/Src/ff.c **** 			rv /= 10; n++;
6974:./ThirdParty/FatFs/Src/ff.c **** 		}
6975:./ThirdParty/FatFs/Src/ff.c **** 	}
6976:./ThirdParty/FatFs/Src/ff.c **** 	return rv;
6977:./ThirdParty/FatFs/Src/ff.c **** }
6978:./ThirdParty/FatFs/Src/ff.c **** 
6979:./ThirdParty/FatFs/Src/ff.c **** 
6980:./ThirdParty/FatFs/Src/ff.c **** static void ftoa (
6981:./ThirdParty/FatFs/Src/ff.c **** 	char* buf,	/* Buffer to output the floating point string */
6982:./ThirdParty/FatFs/Src/ff.c **** 	double val,	/* Value to output */
6983:./ThirdParty/FatFs/Src/ff.c **** 	int prec,	/* Number of fractional digits */
6984:./ThirdParty/FatFs/Src/ff.c **** 	TCHAR fmt	/* Notation */
6985:./ThirdParty/FatFs/Src/ff.c **** )
6986:./ThirdParty/FatFs/Src/ff.c **** {
6987:./ThirdParty/FatFs/Src/ff.c **** 	int digit;
6988:./ThirdParty/FatFs/Src/ff.c **** 	int exp = 0, mag = 0;
6989:./ThirdParty/FatFs/Src/ff.c **** 	char sign = 0;
6990:./ThirdParty/FatFs/Src/ff.c **** 	double w;
6991:./ThirdParty/FatFs/Src/ff.c **** 	const char *er = 0;
6992:./ThirdParty/FatFs/Src/ff.c **** 	const char ds = FF_PRINT_FLOAT == 2 ? ',' : '.';
6993:./ThirdParty/FatFs/Src/ff.c **** 
6994:./ThirdParty/FatFs/Src/ff.c **** 
6995:./ThirdParty/FatFs/Src/ff.c **** 	if (isnan(val)) {			/* Not a number? */
6996:./ThirdParty/FatFs/Src/ff.c **** 		er = "NaN";
6997:./ThirdParty/FatFs/Src/ff.c **** 	} else {
6998:./ThirdParty/FatFs/Src/ff.c **** 		if (prec < 0) prec = 6;	/* Default precision? (6 fractional digits) */
6999:./ThirdParty/FatFs/Src/ff.c **** 		if (val < 0) {			/* Negative? */
7000:./ThirdParty/FatFs/Src/ff.c **** 			val = 0 - val; sign = '-';
7001:./ThirdParty/FatFs/Src/ff.c **** 		} else {
7002:./ThirdParty/FatFs/Src/ff.c **** 			sign = '+';
7003:./ThirdParty/FatFs/Src/ff.c **** 		}
7004:./ThirdParty/FatFs/Src/ff.c **** 		if (isinf(val)) {		/* Infinite? */
7005:./ThirdParty/FatFs/Src/ff.c **** 			er = "INF";
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccTDbepL.s 			page 327


7006:./ThirdParty/FatFs/Src/ff.c **** 		} else {
7007:./ThirdParty/FatFs/Src/ff.c **** 			if (fmt == 'f') {	/* Decimal notation? */
7008:./ThirdParty/FatFs/Src/ff.c **** 				val += i10x(0 - prec) / 2;	/* Round (nearest) */
7009:./ThirdParty/FatFs/Src/ff.c **** 				mag = ilog10(val);
7010:./ThirdParty/FatFs/Src/ff.c **** 				if (mag < 0) mag = 0;
7011:./ThirdParty/FatFs/Src/ff.c **** 				if (mag + prec + 3 >= SZ_NUM_BUF) er = "OV";	/* Buffer overflow? */
7012:./ThirdParty/FatFs/Src/ff.c **** 			} else {			/* E notation */
7013:./ThirdParty/FatFs/Src/ff.c **** 				if (val != 0) {		/* Not a true zero? */
7014:./ThirdParty/FatFs/Src/ff.c **** 					val += i10x(ilog10(val) - prec) / 2;	/* Round (nearest) */
7015:./ThirdParty/FatFs/Src/ff.c **** 					exp = ilog10(val);
7016:./ThirdParty/FatFs/Src/ff.c **** 					if (exp > 99 || prec + 7 >= SZ_NUM_BUF) {	/* Buffer overflow or E > +99? */
7017:./ThirdParty/FatFs/Src/ff.c **** 						er = "OV";
7018:./ThirdParty/FatFs/Src/ff.c **** 					} else {
7019:./ThirdParty/FatFs/Src/ff.c **** 						if (exp < -99) exp = -99;
7020:./ThirdParty/FatFs/Src/ff.c **** 						val /= i10x(exp);	/* Normalize */
7021:./ThirdParty/FatFs/Src/ff.c **** 					}
7022:./ThirdParty/FatFs/Src/ff.c **** 				}
7023:./ThirdParty/FatFs/Src/ff.c **** 			}
7024:./ThirdParty/FatFs/Src/ff.c **** 		}
7025:./ThirdParty/FatFs/Src/ff.c **** 		if (!er) {	/* Not error condition */
