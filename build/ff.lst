 968:./Application/FatFs/ff.c **** 			fs->wflag = 1;
 969:./Application/FatFs/ff.c **** 			res = move_window(fs, fs->fatbase + (bc / SS(fs)));
 970:./Application/FatFs/ff.c **** 			if (res != FR_OK) break;
 971:./Application/FatFs/ff.c **** 			p = &fs->win.d8[bc % SS(fs)];
 972:./Application/FatFs/ff.c **** 			*p = (clst & 1) ? (BYTE)(val >> 4) : ((*p & 0xF0) | ((BYTE)(val >> 8) & 0x0F));
 973:./Application/FatFs/ff.c **** 			fs->wflag = 1;
 974:./Application/FatFs/ff.c **** 			break;
 975:./Application/FatFs/ff.c **** 
 976:./Application/FatFs/ff.c **** 		case FS_FAT16 :
 977:./Application/FatFs/ff.c **** 			res = move_window(fs, fs->fatbase + (clst / (SS(fs) / 2)));
 978:./Application/FatFs/ff.c **** 			if (res != FR_OK) break;
 979:./Application/FatFs/ff.c **** 			p = &fs->win.d8[clst * 2 % SS(fs)];
 980:./Application/FatFs/ff.c **** 			ST_WORD(p, (WORD)val);
 981:./Application/FatFs/ff.c **** 			fs->wflag = 1;
 982:./Application/FatFs/ff.c **** 			break;
 983:./Application/FatFs/ff.c **** 
 984:./Application/FatFs/ff.c **** 		case FS_FAT32 :
 985:./Application/FatFs/ff.c **** 			res = move_window(fs, fs->fatbase + (clst / (SS(fs) / 4)));
 986:./Application/FatFs/ff.c **** 			if (res != FR_OK) break;
 987:./Application/FatFs/ff.c **** 			p = &fs->win.d8[clst * 4 % SS(fs)];
 988:./Application/FatFs/ff.c **** 			val |= LD_DWORD(p) & 0xF0000000;
 989:./Application/FatFs/ff.c **** 			ST_DWORD(p, val);
 990:./Application/FatFs/ff.c **** 			fs->wflag = 1;
 991:./Application/FatFs/ff.c **** 			break;
 992:./Application/FatFs/ff.c **** 
 993:./Application/FatFs/ff.c **** 		default :
