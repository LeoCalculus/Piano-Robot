1034:./Application/FatFs/ff.c **** 				fs->free_clust++;
1035:./Application/FatFs/ff.c **** 				fs->fsi_flag |= 1;
1036:./Application/FatFs/ff.c **** 			}
1037:./Application/FatFs/ff.c **** #if _USE_TRIM
1038:./Application/FatFs/ff.c **** 			if (ecl + 1 == nxt) {	/* Is next cluster contiguous? */
