2878:./Application/FatFs/ff.c **** /* Synchronize the File                                                  */
2879:./Application/FatFs/ff.c **** /*-----------------------------------------------------------------------*/
2880:./Application/FatFs/ff.c **** 
2881:./Application/FatFs/ff.c **** FRESULT f_sync (
2882:./Application/FatFs/ff.c **** 	FIL* fp		/* Pointer to the file object */
2883:./Application/FatFs/ff.c **** )
2884:./Application/FatFs/ff.c **** {
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccJzsbqh.s 			page 174


2885:./Application/FatFs/ff.c **** 	FRESULT res;
2886:./Application/FatFs/ff.c **** 	DWORD tm;
2887:./Application/FatFs/ff.c **** 	BYTE *dir;
2888:./Application/FatFs/ff.c **** 
2889:./Application/FatFs/ff.c **** 
2890:./Application/FatFs/ff.c **** 	res = validate(fp);					/* Check validity of the object */
2891:./Application/FatFs/ff.c **** 	if (res == FR_OK) {
2892:./Application/FatFs/ff.c **** 		if (fp->flag & FA__WRITTEN) {	/* Has the file been written? */
2893:./Application/FatFs/ff.c **** 			/* Write-back dirty buffer */
2894:./Application/FatFs/ff.c **** #if !_FS_TINY
2895:./Application/FatFs/ff.c **** 			if (fp->flag & FA__DIRTY) {
2896:./Application/FatFs/ff.c **** 				if (disk_write(fp->fs->drv, fp->buf.d8, fp->dsect, 1) != RES_OK)
2897:./Application/FatFs/ff.c **** 					LEAVE_FF(fp->fs, FR_DISK_ERR);
2898:./Application/FatFs/ff.c **** 				fp->flag &= ~FA__DIRTY;
2899:./Application/FatFs/ff.c **** 			}
2900:./Application/FatFs/ff.c **** #endif
2901:./Application/FatFs/ff.c **** 			/* Update the directory entry */
2902:./Application/FatFs/ff.c **** 			res = move_window(fp->fs, fp->dir_sect);
2903:./Application/FatFs/ff.c **** 			if (res == FR_OK) {
2904:./Application/FatFs/ff.c **** 				dir = fp->dir_ptr;
2905:./Application/FatFs/ff.c **** 				dir[DIR_Attr] |= AM_ARC;					/* Set archive bit */
2906:./Application/FatFs/ff.c **** 				ST_DWORD(dir + DIR_FileSize, fp->fsize);	/* Update file size */
2907:./Application/FatFs/ff.c **** 				st_clust(dir, fp->sclust);					/* Update start cluster */
2908:./Application/FatFs/ff.c **** 				tm = GET_FATTIME();							/* Update updated time */
2909:./Application/FatFs/ff.c **** 				ST_DWORD(dir + DIR_WrtTime, tm);
2910:./Application/FatFs/ff.c **** 				ST_WORD(dir + DIR_LstAccDate, 0);
2911:./Application/FatFs/ff.c **** 				fp->flag &= ~FA__WRITTEN;
2912:./Application/FatFs/ff.c **** 				fp->fs->wflag = 1;
2913:./Application/FatFs/ff.c **** 				res = sync_fs(fp->fs);
2914:./Application/FatFs/ff.c **** 			}
2915:./Application/FatFs/ff.c **** 		}
2916:./Application/FatFs/ff.c **** 	}
2917:./Application/FatFs/ff.c **** 
2918:./Application/FatFs/ff.c **** 	LEAVE_FF(fp->fs, res);
2919:./Application/FatFs/ff.c **** }
