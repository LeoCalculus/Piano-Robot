2149:./Application/FatFs/ff.c **** 	} else {								/* Follow path */
2150:./Application/FatFs/ff.c **** 		for (;;) {
2151:./Application/FatFs/ff.c **** 			res = create_name(dp, &path);	/* Get a segment name of the path */
2152:./Application/FatFs/ff.c **** 			if (res != FR_OK) break;
2153:./Application/FatFs/ff.c **** 			res = dir_find(dp);				/* Find an object with the sagment name */
2154:./Application/FatFs/ff.c **** 			ns = dp->fn[NSFLAG];
2155:./Application/FatFs/ff.c **** 			if (res != FR_OK) {				/* Failed to find the object */
2156:./Application/FatFs/ff.c **** 				if (res == FR_NO_FILE) {	/* Object is not found */
2157:./Application/FatFs/ff.c **** 					if (_FS_RPATH && (ns & NS_DOT)) {	/* If dot entry is not exist, */
2158:./Application/FatFs/ff.c **** 						dp->sclust = 0; dp->dir = 0;	/* it is the root directory and stay there */
2159:./Application/FatFs/ff.c **** 						if (!(ns & NS_LAST)) continue;	/* Continue to follow if not last segment */
2160:./Application/FatFs/ff.c **** 						res = FR_OK;					/* Ended at the root directroy. Function completed. */
2161:./Application/FatFs/ff.c **** 					} else {							/* Could not find the object */
2162:./Application/FatFs/ff.c **** 						if (!(ns & NS_LAST)) res = FR_NO_PATH;	/* Adjust error code if not last segment */
2163:./Application/FatFs/ff.c **** 					}
2164:./Application/FatFs/ff.c **** 				}
2165:./Application/FatFs/ff.c **** 				break;
2166:./Application/FatFs/ff.c **** 			}
2167:./Application/FatFs/ff.c **** 			if (ns & NS_LAST) break;			/* Last segment matched. Function completed. */
2168:./Application/FatFs/ff.c **** 			dir = dp->dir;						/* Follow the sub-directory */
2169:./Application/FatFs/ff.c **** 			if (!(dir[DIR_Attr] & AM_DIR)) {	/* It is not a sub-directory and cannot follow */
2170:./Application/FatFs/ff.c **** 				res = FR_NO_PATH; break;
2171:./Application/FatFs/ff.c **** 			}
2172:./Application/FatFs/ff.c **** 			dp->sclust = ld_clust(dp->fs, dir);
2173:./Application/FatFs/ff.c **** 		}
2174:./Application/FatFs/ff.c **** 	}
2175:./Application/FatFs/ff.c **** 
