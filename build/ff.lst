2929:./Application/FatFs/ff.c **** 
2930:./Application/FatFs/ff.c **** FRESULT f_close (
2931:./Application/FatFs/ff.c **** 	FIL *fp		/* Pointer to the file object to be closed */
2932:./Application/FatFs/ff.c **** )
2933:./Application/FatFs/ff.c **** {
2934:./Application/FatFs/ff.c **** 	FRESULT res;
2935:./Application/FatFs/ff.c **** 
