2888:./ThirdParty/FatFs/ff.c **** 
2889:./ThirdParty/FatFs/ff.c **** 
2890:./ThirdParty/FatFs/ff.c **** 	res = validate(fp);					/* Check validity of the object */
2891:./ThirdParty/FatFs/ff.c **** 	if (res == FR_OK) {
2892:./ThirdParty/FatFs/ff.c **** 		if (fp->flag & FA__WRITTEN) {	/* Has the file been written? */
2893:./ThirdParty/FatFs/ff.c **** 			/* Write-back dirty buffer */
2894:./ThirdParty/FatFs/ff.c **** #if !_FS_TINY
2895:./ThirdParty/FatFs/ff.c **** 			if (fp->flag & FA__DIRTY) {
2896:./ThirdParty/FatFs/ff.c **** 				if (disk_write(fp->fs->drv, fp->buf.d8, fp->dsect, 1) != RES_OK)
2897:./ThirdParty/FatFs/ff.c **** 					LEAVE_FF(fp->fs, FR_DISK_ERR);
2898:./ThirdParty/FatFs/ff.c **** 				fp->flag &= ~FA__DIRTY;
2899:./ThirdParty/FatFs/ff.c **** 			}
2900:./ThirdParty/FatFs/ff.c **** #endif
2901:./ThirdParty/FatFs/ff.c **** 			/* Update the directory entry */
2902:./ThirdParty/FatFs/ff.c **** 			res = move_window(fp->fs, fp->dir_sect);
2903:./ThirdParty/FatFs/ff.c **** 			if (res == FR_OK) {
2904:./ThirdParty/FatFs/ff.c **** 				dir = fp->dir_ptr;
