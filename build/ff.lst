3740:./ThirdParty/FatFs/Src/ff.c **** 	FATFS* fs,			/* Pointer to the filesystem object to be registered (NULL:unmount)*/
3741:./ThirdParty/FatFs/Src/ff.c **** 	const TCHAR* path,	/* Logical drive number to be mounted/unmounted */
3742:./ThirdParty/FatFs/Src/ff.c **** 	BYTE opt			/* Mount option: 0=Do not mount (delayed mount), 1=Mount immediately */
3743:./ThirdParty/FatFs/Src/ff.c **** )
3744:./ThirdParty/FatFs/Src/ff.c **** {
3745:./ThirdParty/FatFs/Src/ff.c **** 	FATFS *cfs;
