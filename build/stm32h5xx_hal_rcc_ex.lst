5757:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCDIV[2:0] bits according to Prescaler value */
5758:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCSRC[1:0] bits according to Source value */
5759:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCSPOL bit according to Polarity value */
5760:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   value = (pInit->Prescaler | pInit->Source | pInit->Polarity);
5761:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the RELOAD[15:0] bits according to ReloadValue value */
5762:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   value |= pInit->ReloadValue;
5763:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the FELIM[7:0] bits according to ErrorLimitValue value */
5764:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   value |= (pInit->ErrorLimitValue << CRS_CFGR_FELIM_Pos);
5765:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   WRITE_REG(CRS->CFGR, value);
5766:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c **** 
5767:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Adjust HSI48 oscillator smooth trimming */
5768:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the TRIM[5:0] bits according to RCC_CRS_HSI48CalibrationValue value */
5769:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   MODIFY_REG(CRS->CR, CRS_CR_TRIM, (pInit->HSI48CalibrationValue << CRS_CR_TRIM_Pos));
5770:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c **** 
5771:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* START AUTOMATIC SYNCHRONIZATION*/
5772:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c **** 
5773:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Enable Automatic trimming & Frequency error counter */
