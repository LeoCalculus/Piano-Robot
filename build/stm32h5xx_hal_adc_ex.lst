6094:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h ****                                                      uint32_t AWDThresholdLowValue)
6095:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h **** {
