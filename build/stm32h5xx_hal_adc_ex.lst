6091:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h ****   * @retval None
6092:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h ****   */
