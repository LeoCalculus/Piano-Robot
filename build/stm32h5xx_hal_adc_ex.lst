5654:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h ****              & (ADC_DIFSEL_DIFSEL >> (SingleDiff & ADC_SINGLEDIFF_CHANNEL_SHIFT_MASK)));
5655:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h **** }
