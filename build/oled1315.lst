 113:./Application/Src/oled1315.c **** 
 114:./Application/Src/oled1315.c **** void OLED_Init(void) {
 115:./Application/Src/oled1315.c ****     // wait for OLED to powerup
 116:./Application/Src/oled1315.c ****     HAL_Delay(100);
 117:./Application/Src/oled1315.c ****     // Do not display on set up time
 118:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xAE);
 119:./Application/Src/oled1315.c ****     // display geometry setup
 120:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xA8);
 121:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x3F);
 122:./Application/Src/oled1315.c ****     // display offset
 123:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xD3);
 124:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x00);
 125:./Application/Src/oled1315.c ****     // start line = 0
 126:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x40);
 127:./Application/Src/oled1315.c ****     // enable dc-dc pump 
 128:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x8D);
 129:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x14);
 130:./Application/Src/oled1315.c ****     // write horizontally 
 131:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x20);
 132:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x00);
 133:./Application/Src/oled1315.c ****     // orientation -> depend on the direction of OLED
 134:./Application/Src/oled1315.c ****     // here rotate 180 deg
 135:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xA1);
 136:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xC8);
 137:./Application/Src/oled1315.c ****     // 128 * 64 display mode
 138:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xDA);
 139:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x12);
 140:./Application/Src/oled1315.c ****     // display with brighter pixels
 141:./Application/Src/oled1315.c ****     OLED_WriteCommand(0x81);
 142:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xCF);
 143:./Application/Src/oled1315.c ****     // display depend on RAM, normal display
 144:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xA4);
 145:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xA6);
 146:./Application/Src/oled1315.c ****     // clear content avoid random stuff
 147:./Application/Src/oled1315.c ****     OLED_Clear();
 148:./Application/Src/oled1315.c ****     // enable the final display
 149:./Application/Src/oled1315.c ****     OLED_WriteCommand(0xAF);
 150:./Application/Src/oled1315.c **** 
 151:./Application/Src/oled1315.c **** }
 152:./Application/Src/oled1315.c **** 
