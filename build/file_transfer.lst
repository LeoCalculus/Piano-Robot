 266:./Application/Src/file_transfer.c **** /* Handle RAM packet data
 267:./Application/Src/file_transfer.c ****    Packet: [0xE1] [row_lo] [row_hi] [56 bytes = 14 floats] [checksum]
 268:./Application/Src/file_transfer.c ****    Total = 60 bytes
 269:./Application/Src/file_transfer.c **** */
 270:./Application/Src/file_transfer.c **** static int FT_HandleRAMData(uint8_t *packet, uint16_t length){
 271:./Application/Src/file_transfer.c ****     // Packet must be exactly 60 bytes: cmd(1) + row(2) + data(56) + checksum(1)
 272:./Application/Src/file_transfer.c ****     if (length != 60)
 273:./Application/Src/file_transfer.c ****     {
 274:./Application/Src/file_transfer.c ****         uint8_t nakData[] = {0, 0, FT_ERR_OVERFLOW};
 275:./Application/Src/file_transfer.c ****         FT_SendResponse(FT_RSP_NAK, nakData, 3);
 276:./Application/Src/file_transfer.c ****         return -1;
 277:./Application/Src/file_transfer.c ****     }
 278:./Application/Src/file_transfer.c **** 
 279:./Application/Src/file_transfer.c ****     // Extract row index early so NAK responses can include it
 280:./Application/Src/file_transfer.c ****     uint16_t rowIndex = packet[1] | (packet[2] << 8);
 281:./Application/Src/file_transfer.c **** 
 282:./Application/Src/file_transfer.c ****     // Verify checksum: XOR of bytes [0..58], compare with byte [59]
 283:./Application/Src/file_transfer.c ****     if (RAM_CalculateChecksum(packet, length - 1) != packet[length - 1])
 284:./Application/Src/file_transfer.c ****     {
 285:./Application/Src/file_transfer.c ****         uint8_t nakData[] = {rowIndex & 0xFF, rowIndex >> 8, FT_ERR_CHECKSUM};
 286:./Application/Src/file_transfer.c ****         FT_SendResponse(FT_RSP_NAK, nakData, 3);
 287:./Application/Src/file_transfer.c ****         return -1;
 288:./Application/Src/file_transfer.c ****     }
 289:./Application/Src/file_transfer.c **** 
 290:./Application/Src/file_transfer.c ****     // Validate row index (0-364)
 291:./Application/Src/file_transfer.c ****     if (rowIndex >= 365)
 292:./Application/Src/file_transfer.c ****     {
 293:./Application/Src/file_transfer.c ****         uint8_t nakData[] = {rowIndex & 0xFF, rowIndex >> 8, FT_ERR_OVERFLOW};
 294:./Application/Src/file_transfer.c ****         FT_SendResponse(FT_RSP_NAK, nakData, 3);
 295:./Application/Src/file_transfer.c ****         return -1;
 296:./Application/Src/file_transfer.c ****     }
 297:./Application/Src/file_transfer.c **** 
 298:./Application/Src/file_transfer.c ****     // Copy 14 floats (56 bytes) into song_ram[rowIndex]
 299:./Application/Src/file_transfer.c ****     memcpy(song_ram[rowIndex], &packet[3], 56);
 300:./Application/Src/file_transfer.c ****     ram_rx_offset += 56;
 301:./Application/Src/file_transfer.c ****     // Tell PC this row is OK
 302:./Application/Src/file_transfer.c ****     uint8_t ackData[] = {rowIndex & 0xFF, rowIndex >> 8};
 303:./Application/Src/file_transfer.c ****     FT_SendResponse(FT_RSP_ACK, ackData, 2);
 304:./Application/Src/file_transfer.c ****     return 0;
 305:./Application/Src/file_transfer.c **** }
