 347:./Application/Src/file_transfer.c **** /* Check for timeout during transfer */
 348:./Application/Src/file_transfer.c **** void FT_TimeoutCheck(void) {
 349:./Application/Src/file_transfer.c ****     if (ftContext.state == FT_STATE_RECEIVING) {
 350:./Application/Src/file_transfer.c ****         uint32_t elapsed = HAL_GetTick() - ftContext.lastActivityTime;
