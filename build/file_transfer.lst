 271:./Application/Src/file_transfer.c **** */
 272:./Application/Src/file_transfer.c **** static int FT_HandleRAMData(uint8_t *packet, uint16_t length){
 273:./Application/Src/file_transfer.c ****     // Packet must be exactly 60 bytes: cmd(1) + row(2) + data(56) + checksum(1)
 274:./Application/Src/file_transfer.c ****     if (length != 60)
 275:./Application/Src/file_transfer.c ****     {
 276:./Application/Src/file_transfer.c ****         uint8_t nakData[] = {0, 0, FT_ERR_OVERFLOW};
 277:./Application/Src/file_transfer.c ****         FT_SendResponse(FT_RSP_NAK, nakData, 3);
 278:./Application/Src/file_transfer.c ****         return -1;
 279:./Application/Src/file_transfer.c ****     }
 280:./Application/Src/file_transfer.c **** 
 281:./Application/Src/file_transfer.c ****     // Extract row index early so NAK responses can include it
 282:./Application/Src/file_transfer.c ****     uint16_t rowIndex = packet[1] | (packet[2] << 8);
 283:./Application/Src/file_transfer.c **** 
 284:./Application/Src/file_transfer.c ****     // Verify checksum: XOR of bytes [0..58], compare with byte [59]
 285:./Application/Src/file_transfer.c ****     if (RAM_CalculateChecksum(packet, length - 1) != packet[length - 1])
 286:./Application/Src/file_transfer.c ****     {
 287:./Application/Src/file_transfer.c ****         uint8_t nakData[] = {rowIndex & 0xFF, rowIndex >> 8, FT_ERR_CHECKSUM};
 288:./Application/Src/file_transfer.c ****         FT_SendResponse(FT_RSP_NAK, nakData, 3);
 289:./Application/Src/file_transfer.c ****         return -1;
 290:./Application/Src/file_transfer.c ****     }
 291:./Application/Src/file_transfer.c **** 
 292:./Application/Src/file_transfer.c ****     // Validate row index (0-364)
 293:./Application/Src/file_transfer.c ****     if (rowIndex >= 365)
 294:./Application/Src/file_transfer.c ****     {
 295:./Application/Src/file_transfer.c ****         uint8_t nakData[] = {rowIndex & 0xFF, rowIndex >> 8, FT_ERR_OVERFLOW};
 296:./Application/Src/file_transfer.c ****         FT_SendResponse(FT_RSP_NAK, nakData, 3);
 297:./Application/Src/file_transfer.c ****         return -1;
 298:./Application/Src/file_transfer.c ****     }
 299:./Application/Src/file_transfer.c **** 
 300:./Application/Src/file_transfer.c ****     // Copy 14 floats (56 bytes) into song_ram[rowIndex]
 301:./Application/Src/file_transfer.c ****     memcpy(song_ram[rowIndex], &packet[3], 56);
 302:./Application/Src/file_transfer.c ****     ram_rx_offset += 56;
 303:./Application/Src/file_transfer.c **** 
 304:./Application/Src/file_transfer.c ****     RAM_track_index++;
 305:./Application/Src/file_transfer.c ****     // Tell PC this row is OK
 306:./Application/Src/file_transfer.c ****     uint8_t ackData[] = {rowIndex & 0xFF, rowIndex >> 8};
 307:./Application/Src/file_transfer.c ****     FT_SendResponse(FT_RSP_ACK, ackData, 2);
 308:./Application/Src/file_transfer.c ****     return 0;
 309:./Application/Src/file_transfer.c **** }
