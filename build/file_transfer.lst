 340:./Application/Src/file_transfer.c **** 
 341:./Application/Src/file_transfer.c ****         default:
 342:./Application/Src/file_transfer.c ****             FT_SendResponse(FT_RSP_ERROR, (uint8_t[]){FT_ERR_SEQUENCE}, 1);
 343:./Application/Src/file_transfer.c ****             break;
 344:./Application/Src/file_transfer.c ****     }
 345:./Application/Src/file_transfer.c **** }
