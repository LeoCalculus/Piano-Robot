8179:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim.c ****   *          This parameter must be a value between 0x00 and 0x0F
8180:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim.c ****   * @retval None
8181:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim.c ****   */
