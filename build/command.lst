 228:./Application/Src/command.c ****     for (int i = 0; i < fileCount; i++) {
 229:./Application/Src/command.c ****         /* Wait until UART TX is idle before sending next entry */
 230:./Application/Src/command.c ****         while (huart2.gState != HAL_UART_STATE_READY) { /* spin */ }
