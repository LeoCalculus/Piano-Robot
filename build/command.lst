 232:./Application/Src/command.c ****     }
 233:./Application/Src/command.c ****     while (huart2.gState != HAL_UART_STATE_READY) { /* spin */ }
 234:./Application/Src/command.c ****     pkt_send_file_list_end((uint8_t)fileCount);
 235:./Application/Src/command.c **** }
