 187:./Application/Src/command.c **** void execute_command(uint8_t *command)
 188:./Application/Src/command.c **** {
 189:./Application/Src/command.c ****     int result = parse_command(command);
 190:./Application/Src/command.c ****     if (result == 0)
 191:./Application/Src/command.c ****     {
 192:./Application/Src/command.c ****         LCD_draw_string(0, 14, "OK.                      ", COLOR_BLACK, COLOR_WHITE);
 193:./Application/Src/command.c ****         LCD_draw_string(0, 15, "                         ", COLOR_BLACK, COLOR_WHITE);
 194:./Application/Src/command.c ****     }
 195:./Application/Src/command.c ****     else if (result == 1)
 196:./Application/Src/command.c ****     {
 197:./Application/Src/command.c ****         LCD_draw_string(0, 14, "Cannot parse!            ", COLOR_BLACK, COLOR_WHITE);
 198:./Application/Src/command.c ****         LCD_draw_string(0, 15, (char*)command, COLOR_BLACK, COLOR_WHITE);
 199:./Application/Src/command.c ****     }
 200:./Application/Src/command.c ****     else if (result == 2)
 201:./Application/Src/command.c ****     {
ARM GAS  C:\Users\admin\AppData\Local\Temp\ccR2JeRl.s 			page 5


 202:./Application/Src/command.c ****         LCD_draw_string(0, 14, "Empty command!           ", COLOR_BLACK, COLOR_WHITE);
