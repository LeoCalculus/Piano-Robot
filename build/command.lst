 251:./Application/Src/command.c ****         }
 252:./Application/Src/command.c **** 
 253:./Application/Src/command.c ****     }
 254:./Application/Src/command.c **** 
 255:./Application/Src/command.c ****     if (chord_events[traversal_index].long_pressed[1]){ // right hand long press
 256:./Application/Src/command.c ****         for (int i = 7; i < 10; i++) {
