 162:./Application/Src/command.c ****     {
 163:./Application/Src/command.c ****         LCD_draw_string(0, 14, "Cannot parse!            ", COLOR_BLACK, COLOR_WHITE);
 164:./Application/Src/command.c ****         LCD_draw_string(0, 15, (char*)command, COLOR_BLACK, COLOR_WHITE);
 165:./Application/Src/command.c ****     }
 166:./Application/Src/command.c ****     else if (result == 2)
 167:./Application/Src/command.c ****     {
 168:./Application/Src/command.c ****         LCD_draw_string(0, 14, "Empty command!           ", COLOR_BLACK, COLOR_WHITE);
 169:./Application/Src/command.c ****     }
