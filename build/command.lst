  10:./Application/Src/command.c **** int parseCommand(uint8_t* cmd) {
  11:./Application/Src/command.c ****     /* ---- Colon commands (:p, :w, :s, :r, :d, :a) ---- */
  12:./Application/Src/command.c ****     if (cmd[0] == ':') {
  13:./Application/Src/command.c ****         switch (cmd[1]) {
  14:./Application/Src/command.c ****             case 'p': { /* :p <value> — set position in mm */
  15:./Application/Src/command.c ****                 char* arg = (char*)cmd + 2;
  16:./Application/Src/command.c ****                 while (*arg == ' ') arg++;
  17:./Application/Src/command.c ****                 if (*arg == '\0') return 3; /* incomplete */
  18:./Application/Src/command.c ****                 float pos = strtof(arg, NULL);
  19:./Application/Src/command.c ****                 setPos(pos);
  20:./Application/Src/command.c ****                 return 0;
  21:./Application/Src/command.c ****             }
  22:./Application/Src/command.c ****             case 'w': /* :w — menu move up */
  23:./Application/Src/command.c ****                 menu_move_up = 1;
  24:./Application/Src/command.c ****                 return 0;
  25:./Application/Src/command.c ****             case 's': /* :s — menu move down */
  26:./Application/Src/command.c ****                 menu_move_down = 1;
  27:./Application/Src/command.c ****                 return 0;
  28:./Application/Src/command.c ****             case 'r': /* :r — reset encoder position */
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccMPy92t.s 			page 2


  29:./Application/Src/command.c ****                 resetPos(&htim8);
  30:./Application/Src/command.c ****                 return 0;
  31:./Application/Src/command.c ****             case 'd': /* :d — enter / select current menu item */
  32:./Application/Src/command.c ****                 menu_enter = 1;
  33:./Application/Src/command.c ****                 return 0;
  34:./Application/Src/command.c ****             case 'a': /* :a — back to main menu */
  35:./Application/Src/command.c ****                 menu_back = 1;
  36:./Application/Src/command.c ****                 return 0;
  37:./Application/Src/command.c ****             default:
  38:./Application/Src/command.c ****                 return 1; /* unknown colon command */
  39:./Application/Src/command.c ****         }
  40:./Application/Src/command.c ****     }
  41:./Application/Src/command.c **** 
  42:./Application/Src/command.c ****     /* ---- Slash commands (/setText, /setPos, /resetPos, /listFiles) ---- */
  43:./Application/Src/command.c ****     if (cmd[0] != '/') {
  44:./Application/Src/command.c ****         return 1; /* unrecognised */
  45:./Application/Src/command.c ****     }
  46:./Application/Src/command.c **** 
  47:./Application/Src/command.c ****     char* command = strtok((char*)cmd + 1, " ");
  48:./Application/Src/command.c ****     if (command == NULL) return 2; /* empty */
  49:./Application/Src/command.c **** 
  50:./Application/Src/command.c ****     char* argument1 = strtok(NULL, " ");
  51:./Application/Src/command.c **** 
  52:./Application/Src/command.c ****     if (strcmp(command, "setText") == 0) {
  53:./Application/Src/command.c ****         if (argument1 == NULL) return 3;
  54:./Application/Src/command.c ****         setText((uint8_t*)argument1);
  55:./Application/Src/command.c ****     } else if (strcmp(command, "setPos") == 0) {
  56:./Application/Src/command.c ****         if (argument1 == NULL) return 3;
  57:./Application/Src/command.c ****         float pos = strtof(argument1, NULL);
  58:./Application/Src/command.c ****         setPos(pos);
  59:./Application/Src/command.c ****     } else if (strcmp(command, "resetPos") == 0) {
  60:./Application/Src/command.c ****         resetPos(&htim8);
  61:./Application/Src/command.c ****     } else if (strcmp(command, "listFiles") == 0) {
  62:./Application/Src/command.c ****         listFilesOverBT();
  63:./Application/Src/command.c ****     } else {
  64:./Application/Src/command.c ****         return 1; /* unknown command */
  65:./Application/Src/command.c ****     }
  66:./Application/Src/command.c **** 
  67:./Application/Src/command.c ****     return 0;
  68:./Application/Src/command.c **** }
  69:./Application/Src/command.c **** 
  70:./Application/Src/command.c **** void executeCommand(uint8_t* command) {
  71:./Application/Src/command.c ****     int result = parseCommand(command);
  72:./Application/Src/command.c ****     if (result == 0) {
  73:./Application/Src/command.c ****         LCD_draw_string(&lcd_config, 0, 14, "OK.                      ", COLOR_BLACK, COLOR_WHITE);
  74:./Application/Src/command.c ****     } else if (result == 1) {
  75:./Application/Src/command.c ****         LCD_draw_string(&lcd_config, 0, 14, "Cannot parse!            ", COLOR_BLACK, COLOR_WHITE);
  76:./Application/Src/command.c ****     } else if (result == 2) {
  77:./Application/Src/command.c ****         LCD_draw_string(&lcd_config, 0, 14, "Empty command!           ", COLOR_BLACK, COLOR_WHITE);
  78:./Application/Src/command.c ****     } else if (result == 3) {
  79:./Application/Src/command.c ****         LCD_draw_string(&lcd_config, 0, 14, "Incomplete command!      ", COLOR_BLACK, COLOR_WHITE);
  80:./Application/Src/command.c ****     }
  81:./Application/Src/command.c **** }
