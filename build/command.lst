 224:./Application/Src/command.c **** void list_files_over_bt(void)
 225:./Application/Src/command.c **** {
 226:./Application/Src/command.c ****     sd_list_txt_files();
 227:./Application/Src/command.c ****     for (int i = 0; i < fileCount; i++) {
 228:./Application/Src/command.c ****         /* Wait until UART TX is idle before sending next entry */
 229:./Application/Src/command.c ****         while (huart2.gState != HAL_UART_STATE_READY) { /* spin */ }
 230:./Application/Src/command.c ****         pkt_send_file_entry(fileList[i].name, fileList[i].size);
 231:./Application/Src/command.c ****     }
 232:./Application/Src/command.c ****     while (huart2.gState != HAL_UART_STATE_READY) { /* spin */ }
 233:./Application/Src/command.c ****     pkt_send_file_list_end((uint8_t)fileCount);
 234:./Application/Src/command.c **** }
