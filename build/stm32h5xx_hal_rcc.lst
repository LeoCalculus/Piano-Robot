  40:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****       (+) Configure the clock source to be used to drive the System clock
  41:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****           (if the application needs higher frequency/performance)
  42:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****       (+) Configure the System clock frequency and Flash settings
  43:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****       (+) Configure the AHB and APB busses prescalers
  44:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****       (+) Enable the clock for the peripheral(s) to be used
  45:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****       (+) Configure the clock source(s) for peripherals which clocks are not
  46:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****           derived from the System clock (SAIx, RTC, ADC, USB, SDMMC, etc.)
  47:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c **** 
  48:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc.c ****   @endverbatim
