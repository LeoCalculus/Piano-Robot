  85:./Application/Src/bt_transfer.c **** static void processHeader(uint8_t byte) {
  86:./Application/Src/bt_transfer.c ****     ctx.headerBuffer[ctx.headerIndex++] = byte;
  87:./Application/Src/bt_transfer.c **** 
  88:./Application/Src/bt_transfer.c ****     /* Header format: [CMD 1B] [NAME_LEN 1B] [NAME n] [SIZE 4B] */
  89:./Application/Src/bt_transfer.c ****     if (ctx.headerIndex >= 2) {
  90:./Application/Src/bt_transfer.c ****         uint8_t cmd = ctx.headerBuffer[0];
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccIayDyL.s 			page 3


  91:./Application/Src/bt_transfer.c ****         uint8_t nameLen = ctx.headerBuffer[1];
  92:./Application/Src/bt_transfer.c **** 
  93:./Application/Src/bt_transfer.c ****         /* Check if we have the complete header */
  94:./Application/Src/bt_transfer.c ****         uint8_t expectedLen = 2 + nameLen + 4;
  95:./Application/Src/bt_transfer.c ****         if (ctx.headerIndex >= expectedLen) {
  96:./Application/Src/bt_transfer.c ****             if (cmd != BT_CMD_FILE_TRANSFER) {
  97:./Application/Src/bt_transfer.c ****                 handleError("Invalid command");
  98:./Application/Src/bt_transfer.c ****                 return;
  99:./Application/Src/bt_transfer.c ****             }
 100:./Application/Src/bt_transfer.c **** 
 101:./Application/Src/bt_transfer.c ****             /* Extract filename */
 102:./Application/Src/bt_transfer.c ****             if (nameLen >= BT_MAX_FILENAME) {
 103:./Application/Src/bt_transfer.c ****                 nameLen = BT_MAX_FILENAME - 1;
 104:./Application/Src/bt_transfer.c ****             }
 105:./Application/Src/bt_transfer.c ****             memcpy(ctx.filename, &ctx.headerBuffer[2], nameLen);
 106:./Application/Src/bt_transfer.c ****             ctx.filename[nameLen] = '\0';
 107:./Application/Src/bt_transfer.c **** 
 108:./Application/Src/bt_transfer.c ****             /* Extract file size (little-endian) */
 109:./Application/Src/bt_transfer.c ****             uint8_t* sizePtr = &ctx.headerBuffer[2 + nameLen];
 110:./Application/Src/bt_transfer.c ****             ctx.fileSize = sizePtr[0] | (sizePtr[1] << 8) |
 111:./Application/Src/bt_transfer.c ****                           (sizePtr[2] << 16) | (sizePtr[3] << 24);
 112:./Application/Src/bt_transfer.c **** 
 113:./Application/Src/bt_transfer.c ****             ctx.bytesReceived = 0;
 114:./Application/Src/bt_transfer.c ****             ctx.expectedChunk = 0;
 115:./Application/Src/bt_transfer.c ****             ctx.totalChunks = (ctx.fileSize + BT_CHUNK_SIZE - 1) / BT_CHUNK_SIZE;
 116:./Application/Src/bt_transfer.c **** 
 117:./Application/Src/bt_transfer.c ****             /* Open file for writing */
 118:./Application/Src/bt_transfer.c ****             FRESULT res = f_open(&ctx.file, ctx.filename, FA_WRITE | FA_CREATE_ALWAYS);
 119:./Application/Src/bt_transfer.c ****             if (res != FR_OK) {
 120:./Application/Src/bt_transfer.c ****                 handleError("Failed to create file");
 121:./Application/Src/bt_transfer.c ****                 return;
 122:./Application/Src/bt_transfer.c ****             }
 123:./Application/Src/bt_transfer.c ****             ctx.fileOpen = 1;
 124:./Application/Src/bt_transfer.c **** 
 125:./Application/Src/bt_transfer.c ****             /* Ready for chunks */
 126:./Application/Src/bt_transfer.c ****             ctx.state = BT_STATE_IDLE;
 127:./Application/Src/bt_transfer.c ****             sendAck();
 128:./Application/Src/bt_transfer.c ****         }
 129:./Application/Src/bt_transfer.c ****     }
 130:./Application/Src/bt_transfer.c **** 
 131:./Application/Src/bt_transfer.c ****     /* Prevent buffer overflow */
 132:./Application/Src/bt_transfer.c ****     if (ctx.headerIndex >= sizeof(ctx.headerBuffer)) {
 133:./Application/Src/bt_transfer.c ****         handleError("Header too long");
 134:./Application/Src/bt_transfer.c ****     }
 135:./Application/Src/bt_transfer.c **** }
 136:./Application/Src/bt_transfer.c **** 
 137:./Application/Src/bt_transfer.c **** static void processChunkHeader(uint8_t byte) {
 138:./Application/Src/bt_transfer.c ****     /* Chunk header: [CHUNK# 2B] [LEN 1B] */
 139:./Application/Src/bt_transfer.c ****     ctx.headerBuffer[ctx.chunkIndex++] = byte;
 140:./Application/Src/bt_transfer.c **** 
 141:./Application/Src/bt_transfer.c ****     if (ctx.chunkIndex >= 3) {
 142:./Application/Src/bt_transfer.c ****         uint16_t chunkNum = ctx.headerBuffer[0] | (ctx.headerBuffer[1] << 8);
 143:./Application/Src/bt_transfer.c ****         ctx.chunkLen = ctx.headerBuffer[2];
 144:./Application/Src/bt_transfer.c **** 
 145:./Application/Src/bt_transfer.c ****         /* Validate chunk */
 146:./Application/Src/bt_transfer.c ****         if (chunkNum != ctx.expectedChunk) {
 147:./Application/Src/bt_transfer.c ****             sendNak();
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccIayDyL.s 			page 4


 148:./Application/Src/bt_transfer.c ****             ctx.state = BT_STATE_IDLE;
 149:./Application/Src/bt_transfer.c ****             return;
 150:./Application/Src/bt_transfer.c ****         }
 151:./Application/Src/bt_transfer.c **** 
 152:./Application/Src/bt_transfer.c ****         if (ctx.chunkLen > BT_CHUNK_SIZE) {
 153:./Application/Src/bt_transfer.c ****             handleError("Chunk too large");
 154:./Application/Src/bt_transfer.c ****             return;
 155:./Application/Src/bt_transfer.c ****         }
 156:./Application/Src/bt_transfer.c **** 
 157:./Application/Src/bt_transfer.c ****         /* Ready to receive chunk data */
 158:./Application/Src/bt_transfer.c ****         ctx.state = BT_STATE_CHUNK_DATA;
 159:./Application/Src/bt_transfer.c ****         ctx.chunkIndex = 0;
 160:./Application/Src/bt_transfer.c ****     }
 161:./Application/Src/bt_transfer.c **** }
 162:./Application/Src/bt_transfer.c **** 
 163:./Application/Src/bt_transfer.c **** static void processChunkData(uint8_t byte) {
 164:./Application/Src/bt_transfer.c ****     ctx.chunkBuffer[ctx.chunkIndex++] = byte;
 165:./Application/Src/bt_transfer.c **** 
 166:./Application/Src/bt_transfer.c ****     if (ctx.chunkIndex >= ctx.chunkLen) {
 167:./Application/Src/bt_transfer.c ****         /* Write chunk to file */
 168:./Application/Src/bt_transfer.c ****         UINT written;
 169:./Application/Src/bt_transfer.c ****         FRESULT res = f_write(&ctx.file, ctx.chunkBuffer, ctx.chunkLen, &written);
 170:./Application/Src/bt_transfer.c **** 
 171:./Application/Src/bt_transfer.c ****         if (res != FR_OK || written != ctx.chunkLen) {
 172:./Application/Src/bt_transfer.c ****             handleError("Write failed");
 173:./Application/Src/bt_transfer.c ****             return;
 174:./Application/Src/bt_transfer.c ****         }
 175:./Application/Src/bt_transfer.c **** 
 176:./Application/Src/bt_transfer.c ****         ctx.bytesReceived += ctx.chunkLen;
 177:./Application/Src/bt_transfer.c ****         ctx.expectedChunk++;
 178:./Application/Src/bt_transfer.c **** 
 179:./Application/Src/bt_transfer.c ****         /* Ready for next chunk */
 180:./Application/Src/bt_transfer.c ****         ctx.state = BT_STATE_IDLE;
 181:./Application/Src/bt_transfer.c ****         sendAck();
 182:./Application/Src/bt_transfer.c ****     }
 183:./Application/Src/bt_transfer.c **** }
