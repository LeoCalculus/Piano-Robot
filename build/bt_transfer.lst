  55:./Application/Src/bt_transfer.c **** static void processIdle(uint8_t byte) {
  56:./Application/Src/bt_transfer.c ****     if (ctx.waitingForMagic2 == 0 && byte == BT_MAGIC_HEADER_0) {
  57:./Application/Src/bt_transfer.c ****         ctx.waitingForMagic2 = 1;
  58:./Application/Src/bt_transfer.c ****     } else if (ctx.waitingForMagic2 == 1) {
  59:./Application/Src/bt_transfer.c ****         ctx.waitingForMagic2 = 0;  /* Clear flag */
  60:./Application/Src/bt_transfer.c ****         if (byte == BT_MAGIC_HEADER_1) {
  61:./Application/Src/bt_transfer.c ****             /* Start of header - reset any previous failed transfer */
  62:./Application/Src/bt_transfer.c ****             if (ctx.fileOpen) {
  63:./Application/Src/bt_transfer.c ****                 f_close(&ctx.file);
  64:./Application/Src/bt_transfer.c ****                 ctx.fileOpen = 0;
  65:./Application/Src/bt_transfer.c ****             }
  66:./Application/Src/bt_transfer.c ****             ctx.state = BT_STATE_HEADER;
  67:./Application/Src/bt_transfer.c ****             ctx.headerIndex = 0;
  68:./Application/Src/bt_transfer.c ****             ctx.bytesReceived = 0;
  69:./Application/Src/bt_transfer.c ****             ctx.expectedChunk = 0;
  70:./Application/Src/bt_transfer.c ****             memset(ctx.headerBuffer, 0, sizeof(ctx.headerBuffer));
  71:./Application/Src/bt_transfer.c ****         } else if (byte == BT_MAGIC_CHUNK_1) {
  72:./Application/Src/bt_transfer.c ****             /* Start of chunk */
  73:./Application/Src/bt_transfer.c ****             ctx.state = BT_STATE_CHUNK_HEADER;
  74:./Application/Src/bt_transfer.c ****             ctx.chunkIndex = 0;
  75:./Application/Src/bt_transfer.c ****         } else if (byte == BT_MAGIC_END_1) {
  76:./Application/Src/bt_transfer.c ****             /* End marker - finish transfer */
  77:./Application/Src/bt_transfer.c ****             finishTransfer();
  78:./Application/Src/bt_transfer.c ****         }
  79:./Application/Src/bt_transfer.c ****         /* Else: not a valid magic sequence, ignore */
  80:./Application/Src/bt_transfer.c ****     } else {
  81:./Application/Src/bt_transfer.c ****         ctx.waitingForMagic2 = 0;
  82:./Application/Src/bt_transfer.c ****     }
  83:./Application/Src/bt_transfer.c **** }
