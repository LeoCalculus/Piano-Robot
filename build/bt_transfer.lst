  34:./Application/Src/bt_transfer.c **** void BT_Transfer_ProcessByte(uint8_t byte) {
  35:./Application/Src/bt_transfer.c ****     switch (ctx.state) {
  36:./Application/Src/bt_transfer.c ****         case BT_STATE_IDLE:
  37:./Application/Src/bt_transfer.c ****             processIdle(byte);
  38:./Application/Src/bt_transfer.c ****             break;
  39:./Application/Src/bt_transfer.c ****         case BT_STATE_HEADER:
  40:./Application/Src/bt_transfer.c ****             processHeader(byte);
  41:./Application/Src/bt_transfer.c ****             break;
  42:./Application/Src/bt_transfer.c ****         case BT_STATE_CHUNK_HEADER:
  43:./Application/Src/bt_transfer.c ****             processChunkHeader(byte);
  44:./Application/Src/bt_transfer.c ****             break;
  45:./Application/Src/bt_transfer.c ****         case BT_STATE_CHUNK_DATA:
  46:./Application/Src/bt_transfer.c ****             processChunkData(byte);
  47:./Application/Src/bt_transfer.c ****             break;
  48:./Application/Src/bt_transfer.c ****         case BT_STATE_COMPLETE:
  49:./Application/Src/bt_transfer.c ****         case BT_STATE_ERROR:
  50:./Application/Src/bt_transfer.c ****             /* Ignore bytes in these states */
  51:./Application/Src/bt_transfer.c ****             break;
  52:./Application/Src/bt_transfer.c ****     }
  53:./Application/Src/bt_transfer.c **** }
