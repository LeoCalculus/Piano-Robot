  14:./ThirdParty/FatFs/Src/diskio.c **** 
  15:./ThirdParty/FatFs/Src/diskio.c **** // CS pin at PC4, SPI instance: SPI1
  16:./ThirdParty/FatFs/Src/diskio.c **** 
  17:./ThirdParty/FatFs/Src/diskio.c **** /* SD card CS pin */
  18:./ThirdParty/FatFs/Src/diskio.c **** #define SD_CS_PORT  SD_CS_GPIO_Port
  19:./ThirdParty/FatFs/Src/diskio.c **** #define SD_CS_PIN   SD_CS_Pin
  20:./ThirdParty/FatFs/Src/diskio.c **** 
  21:./ThirdParty/FatFs/Src/diskio.c **** #define SD_CS_LOW()   HAL_GPIO_WritePin(SD_CS_PORT, SD_CS_PIN, GPIO_PIN_RESET)
  22:./ThirdParty/FatFs/Src/diskio.c **** #define SD_CS_HIGH()  HAL_GPIO_WritePin(SD_CS_PORT, SD_CS_PIN, GPIO_PIN_SET)
  23:./ThirdParty/FatFs/Src/diskio.c **** 
  24:./ThirdParty/FatFs/Src/diskio.c **** /* SD command definitions */
  25:./ThirdParty/FatFs/Src/diskio.c **** #define CMD0    0   /* GO_IDLE_STATE */
  26:./ThirdParty/FatFs/Src/diskio.c **** #define CMD1    1   /* SEND_OP_COND (MMC) */
  27:./ThirdParty/FatFs/Src/diskio.c **** #define CMD8    8   /* SEND_IF_COND */
  28:./ThirdParty/FatFs/Src/diskio.c **** #define CMD9    9   /* SEND_CSD */
  29:./ThirdParty/FatFs/Src/diskio.c **** #define CMD10   10  /* SEND_CID */
  30:./ThirdParty/FatFs/Src/diskio.c **** #define CMD12   12  /* STOP_TRANSMISSION */
