  59:./ThirdParty/FatFs/Src/diskio.c **** /*-----------------------------------------------------------------------*/
  60:./ThirdParty/FatFs/Src/diskio.c **** /* SPI low-level: register-based continuous transfer for STM32H5         */
  61:./ThirdParty/FatFs/Src/diskio.c **** /*                                                                       */
  62:./ThirdParty/FatFs/Src/diskio.c **** /* The H5 SPI HAL enables/disables SPE for every transfer, creating     */
  63:./ThirdParty/FatFs/Src/diskio.c **** /* gaps in the clock. SD cards need continuous clocking within a CS      */
  64:./ThirdParty/FatFs/Src/diskio.c **** /* assertion. We use TSIZE=0 (unlimited) mode and directly access       */
  65:./ThirdParty/FatFs/Src/diskio.c **** /* TXDR/RXDR to keep the clock running.                                 */
  66:./ThirdParty/FatFs/Src/diskio.c **** /*-----------------------------------------------------------------------*/
  67:./ThirdParty/FatFs/Src/diskio.c **** 
