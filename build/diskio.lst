 311:./ThirdParty/FatFs/Src/diskio.c **** 
 312:./ThirdParty/FatFs/Src/diskio.c **** 	/* Send 80+ clock pulses with CS high to put card in SPI mode */
 313:./ThirdParty/FatFs/Src/diskio.c **** 	SD_CS_HIGH();
 314:./ThirdParty/FatFs/Src/diskio.c **** 	spi_begin();
 315:./ThirdParty/FatFs/Src/diskio.c **** 	for (n = 0; n < 20; n++) spi_txrx(0xFF);
 316:./ThirdParty/FatFs/Src/diskio.c **** 	spi_end();
