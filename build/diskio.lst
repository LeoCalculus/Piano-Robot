 324:./ThirdParty/FatFs/Src/diskio.c **** 		sd_dbg_spi_ok = (rx == 0xFF) ? 1 : 0;
 325:./ThirdParty/FatFs/Src/diskio.c **** 		sd_dbg_hal_err = 0;
 326:./ThirdParty/FatFs/Src/diskio.c **** 	}
 327:./ThirdParty/FatFs/Src/diskio.c **** 
 328:./ThirdParty/FatFs/Src/diskio.c **** 	/* CMD0: GO_IDLE_STATE */
 329:./ThirdParty/FatFs/Src/diskio.c **** 	resp = 0xFF;
 330:./ThirdParty/FatFs/Src/diskio.c **** 	for (n = 0; n < 10 && resp != 1; n++) {
 331:./ThirdParty/FatFs/Src/diskio.c **** 		SD_CS_LOW();
 332:./ThirdParty/FatFs/Src/diskio.c **** 		spi_begin();
 333:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0xFF);
 334:./ThirdParty/FatFs/Src/diskio.c **** 
 335:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0x40 | CMD0);
 336:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0x00);
 337:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0x00);
 338:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0x00);
 339:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0x00);
 340:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0x95);
 341:./ThirdParty/FatFs/Src/diskio.c **** 
 342:./ThirdParty/FatFs/Src/diskio.c **** 		{
 343:./ThirdParty/FatFs/Src/diskio.c **** 			BYTE i;
 344:./ThirdParty/FatFs/Src/diskio.c **** 			for (i = 0; i < 10; i++) {
 345:./ThirdParty/FatFs/Src/diskio.c **** 				resp = spi_txrx(0xFF);
 346:./ThirdParty/FatFs/Src/diskio.c **** 				if (!(resp & 0x80)) break;
 347:./ThirdParty/FatFs/Src/diskio.c **** 			}
 348:./ThirdParty/FatFs/Src/diskio.c **** 		}
 349:./ThirdParty/FatFs/Src/diskio.c **** 
 350:./ThirdParty/FatFs/Src/diskio.c **** 		spi_end();
 351:./ThirdParty/FatFs/Src/diskio.c **** 		SD_CS_HIGH();
 352:./ThirdParty/FatFs/Src/diskio.c **** 		spi_begin();
 353:./ThirdParty/FatFs/Src/diskio.c **** 		spi_txrx(0xFF);
 354:./ThirdParty/FatFs/Src/diskio.c **** 		spi_end();
ARM GAS  C:\Users\admin\AppData\Local\Temp\ccVD4maD.s 			page 24


 355:./ThirdParty/FatFs/Src/diskio.c **** 	}
 356:./ThirdParty/FatFs/Src/diskio.c **** 	sd_dbg_cmd0 = resp;
 357:./ThirdParty/FatFs/Src/diskio.c **** 
 358:./ThirdParty/FatFs/Src/diskio.c **** 	ty = 0;
 359:./ThirdParty/FatFs/Src/diskio.c **** 	if (resp == 1) {  /* Card is in idle state */
 360:./ThirdParty/FatFs/Src/diskio.c **** 		start = HAL_GetTick();
 361:./ThirdParty/FatFs/Src/diskio.c **** 
 362:./ThirdParty/FatFs/Src/diskio.c **** 		resp = send_cmd(CMD8, 0x1AA);
 363:./ThirdParty/FatFs/Src/diskio.c **** 		sd_dbg_cmd8 = resp;
 364:./ThirdParty/FatFs/Src/diskio.c **** 
 365:./ThirdParty/FatFs/Src/diskio.c **** 		if (resp == 1) {  /* SDv2 */
 366:./ThirdParty/FatFs/Src/diskio.c **** 			for (n = 0; n < 4; n++) ocr[n] = spi_txrx(0xFF);
 367:./ThirdParty/FatFs/Src/diskio.c **** 
 368:./ThirdParty/FatFs/Src/diskio.c **** 			if (ocr[2] == 0x01 && ocr[3] == 0xAA) {
 369:./ThirdParty/FatFs/Src/diskio.c **** 				/* Wait for leaving idle state (ACMD41 with HCS bit) */
 370:./ThirdParty/FatFs/Src/diskio.c **** 				do {
 371:./ThirdParty/FatFs/Src/diskio.c **** 					resp = send_cmd(ACMD41, 1UL << 30);
 372:./ThirdParty/FatFs/Src/diskio.c **** 					sd_dbg_acmd41 = resp;
 373:./ThirdParty/FatFs/Src/diskio.c **** 				} while (resp && (HAL_GetTick() - start) < 2000);
 374:./ThirdParty/FatFs/Src/diskio.c **** 
 375:./ThirdParty/FatFs/Src/diskio.c **** 				if (resp == 0 && send_cmd(CMD58, 0) == 0) {
 376:./ThirdParty/FatFs/Src/diskio.c **** 					for (n = 0; n < 4; n++) ocr[n] = spi_txrx(0xFF);
 377:./ThirdParty/FatFs/Src/diskio.c **** 					ty = (ocr[0] & 0x40) ? CT_SD2 | CT_BLOCK : CT_SD2;
 378:./ThirdParty/FatFs/Src/diskio.c **** 				}
 379:./ThirdParty/FatFs/Src/diskio.c **** 			}
 380:./ThirdParty/FatFs/Src/diskio.c **** 		} else {  /* SDv1 or MMCv3 */
 381:./ThirdParty/FatFs/Src/diskio.c **** 			if (send_cmd(ACMD41, 0) <= 1) {
 382:./ThirdParty/FatFs/Src/diskio.c **** 				ty = CT_SD1;
 383:./ThirdParty/FatFs/Src/diskio.c **** 				cmd = ACMD41;
 384:./ThirdParty/FatFs/Src/diskio.c **** 			} else {
 385:./ThirdParty/FatFs/Src/diskio.c **** 				ty = CT_MMC;
 386:./ThirdParty/FatFs/Src/diskio.c **** 				cmd = CMD1;
 387:./ThirdParty/FatFs/Src/diskio.c **** 			}
 388:./ThirdParty/FatFs/Src/diskio.c **** 			/* Wait for leaving idle state */
 389:./ThirdParty/FatFs/Src/diskio.c **** 			do {
 390:./ThirdParty/FatFs/Src/diskio.c **** 				resp = send_cmd(cmd, 0);
 391:./ThirdParty/FatFs/Src/diskio.c **** 				sd_dbg_acmd41 = resp;
 392:./ThirdParty/FatFs/Src/diskio.c **** 			} while (resp && (HAL_GetTick() - start) < 2000);
 393:./ThirdParty/FatFs/Src/diskio.c **** 
 394:./ThirdParty/FatFs/Src/diskio.c **** 			/* Set block length to 512 */
 395:./ThirdParty/FatFs/Src/diskio.c **** 			if (resp != 0 || send_cmd(CMD16, 512) != 0)
 396:./ThirdParty/FatFs/Src/diskio.c **** 				ty = 0;
 397:./ThirdParty/FatFs/Src/diskio.c **** 		}
 398:./ThirdParty/FatFs/Src/diskio.c **** 	}
 399:./ThirdParty/FatFs/Src/diskio.c **** 
 400:./ThirdParty/FatFs/Src/diskio.c **** 	CardType = ty;
 401:./ThirdParty/FatFs/Src/diskio.c **** 	sd_dbg_cardtype = ty;
 402:./ThirdParty/FatFs/Src/diskio.c **** 	deselect();
 403:./ThirdParty/FatFs/Src/diskio.c **** 
 404:./ThirdParty/FatFs/Src/diskio.c **** 	if (ty) {
 405:./ThirdParty/FatFs/Src/diskio.c **** 		Stat &= ~STA_NOINIT;
 406:./ThirdParty/FatFs/Src/diskio.c **** 	} else {
 407:./ThirdParty/FatFs/Src/diskio.c **** 		Stat = STA_NOINIT;
 408:./ThirdParty/FatFs/Src/diskio.c **** 	}
 409:./ThirdParty/FatFs/Src/diskio.c **** 
 410:./ThirdParty/FatFs/Src/diskio.c **** 	return Stat;
 411:./ThirdParty/FatFs/Src/diskio.c **** }
