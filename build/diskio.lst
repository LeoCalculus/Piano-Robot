  53:./ThirdParty/FatFs/diskio.c ****     /* Return a fixed timestamp if RTC is not available */
  54:./ThirdParty/FatFs/diskio.c ****     /* Format: bit31:25=Year(0-127 from 1980), bit24:21=Month(1-12),
  55:./ThirdParty/FatFs/diskio.c ****        bit20:16=Day(1-31), bit15:11=Hour(0-23), bit10:5=Min(0-59),
  56:./ThirdParty/FatFs/diskio.c ****        bit4:0=Sec/2(0-29) */
  57:./ThirdParty/FatFs/diskio.c ****     return ((DWORD)(2024 - 1980) << 25)  /* Year 2024 */
 180              		.loc 1 57 5 view .LVU26
  58:./ThirdParty/FatFs/diskio.c ****          | ((DWORD)1 << 21)              /* January */
  59:./ThirdParty/FatFs/diskio.c ****          | ((DWORD)1 << 16)              /* Day 1 */
ARM GAS  C:\Users\Xuleo\AppData\Local\Temp\ccyCc4uB.s 			page 5


  60:./ThirdParty/FatFs/diskio.c ****          | ((DWORD)0 << 11)              /* Hour 0 */
  61:./ThirdParty/FatFs/diskio.c ****          | ((DWORD)0 << 5)               /* Min 0 */
  62:./ThirdParty/FatFs/diskio.c ****          | ((DWORD)0 >> 1);              /* Sec 0 */
  63:./ThirdParty/FatFs/diskio.c **** }
