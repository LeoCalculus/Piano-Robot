   1:./ThirdParty/FatFs/Src/diskio.c **** /*-----------------------------------------------------------------------*/
   2:./ThirdParty/FatFs/Src/diskio.c **** /* Low level disk I/O module for FatFs - SD card over SPI (STM32H5)     */
   3:./ThirdParty/FatFs/Src/diskio.c **** /*                                                                       */
   4:./ThirdParty/FatFs/Src/diskio.c **** /* Uses direct SPI register access with TSIZE=0 (unlimited mode) to     */
   5:./ThirdParty/FatFs/Src/diskio.c **** /* keep the clock running continuously. The H5 HAL starts/stops SPI     */
   6:./ThirdParty/FatFs/Src/diskio.c **** /* per transfer call, creating clock gaps that SD cards reject.         */
   7:./ThirdParty/FatFs/Src/diskio.c **** /*-----------------------------------------------------------------------*/
   8:./ThirdParty/FatFs/Src/diskio.c **** 
   9:./ThirdParty/FatFs/Src/diskio.c **** #include "ff.h"
