  45:./Application/Src/sdcard.c **** 
  46:./Application/Src/sdcard.c ****     // wait for response (0x01 = idle state)
  47:./Application/Src/sdcard.c ****     tx = 0xFF;
  48:./Application/Src/sdcard.c ****     uint8_t response = 0xFF;
  49:./Application/Src/sdcard.c ****     for (int i = 0; i < 100; i++) {
  50:./Application/Src/sdcard.c ****         HAL_SPI_TransmitReceive(hspi, &tx, &response, 1, 100);
  51:./Application/Src/sdcard.c ****         if (response != 0xFF) {
  52:./Application/Src/sdcard.c **** 
  53:./Application/Src/sdcard.c ****         }
  54:./Application/Src/sdcard.c ****         if (response == 0x01) {
  55:./Application/Src/sdcard.c ****             break;
  56:./Application/Src/sdcard.c ****         }
  57:./Application/Src/sdcard.c ****     }
  58:./Application/Src/sdcard.c **** 
  59:./Application/Src/sdcard.c ****     // deselect the card
  60:./Application/Src/sdcard.c ****     HAL_GPIO_WritePin(detectPort, detectPin, GPIO_PIN_SET);
  61:./Application/Src/sdcard.c ****     HAL_SPI_TransmitReceive(hspi, &tx, &rx, 1, 100);
  62:./Application/Src/sdcard.c **** 
  63:./Application/Src/sdcard.c ****     return (response == 0x01) ? 1 : 0;
  64:./Application/Src/sdcard.c **** }
