  16:./Application/Src/sdcard.c ****     uint8_t tx, rx;
  17:./Application/Src/sdcard.c **** 
  18:./Application/Src/sdcard.c ****     // give SD card time to power up
  19:./Application/Src/sdcard.c ****     HAL_Delay(100);
  20:./Application/Src/sdcard.c **** 
  21:./Application/Src/sdcard.c ****     // start with deselect
