  30:./Application/Src/sdcard.c ****     // select SD card
  31:./Application/Src/sdcard.c ****     HAL_GPIO_WritePin(detectPort, detectPin, GPIO_PIN_RESET);
  32:./Application/Src/sdcard.c ****     HAL_Delay(1);
  33:./Application/Src/sdcard.c **** 
  34:./Application/Src/sdcard.c ****     // send CMD0 (GO_IDLE_STATE)
  35:./Application/Src/sdcard.c ****     tx = 0x40 | 0;
  36:./Application/Src/sdcard.c ****     HAL_SPI_TransmitReceive(hspi, &tx, &rx, 1, 100);
  37:./Application/Src/sdcard.c **** 
  38:./Application/Src/sdcard.c ****     tx = 0x00;
  39:./Application/Src/sdcard.c ****     HAL_SPI_TransmitReceive(hspi, &tx, &rx, 1, 100);
  40:./Application/Src/sdcard.c ****     HAL_SPI_TransmitReceive(hspi, &tx, &rx, 1, 100);
