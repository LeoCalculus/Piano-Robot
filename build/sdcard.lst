  23:./Application/Src/sdcard.c **** 
  24:./Application/Src/sdcard.c ****     // wake up sd card by sending 80+ dummy clock cycles (10 bytes) with CS high
  25:./Application/Src/sdcard.c ****     tx = 0xFF;
  26:./Application/Src/sdcard.c ****     for (int i = 0; i < 10; i++) {
  27:./Application/Src/sdcard.c ****         HAL_SPI_TransmitReceive(hspi, &tx, &rx, 1, 100);
